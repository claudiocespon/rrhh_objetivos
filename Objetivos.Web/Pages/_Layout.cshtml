@using Microsoft.AspNetCore.Components.Web
@namespace Objetivos.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="icon" type="image/png" href="Pqtalent.png">
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/material-base.css">
    <link rel="stylesheet" href="css/site.css">
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
    <script src="_framework/blazor.server.js"></script>
    <script src="js/login-animation.js"></script>
    <script>
        window.antigravityDownloadFile = (fileName, base64Data) => {
            const link = document.createElement('a');
            link.download = fileName;
            link.href = 'data:application/octet-stream;base64,' + base64Data;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };

        // C-07: Auto-scroll al fondo del contenedor de chat
        window.scrollToBottom = (id) => {
            var el = document.getElementById(id);
            if (el) el.scrollTop = el.scrollHeight;
        };

        // MutationObserver to add HTML 'title' tooltips to all RadzenDataGrid cells
        const observer = new MutationObserver((mutations) => {
            document.querySelectorAll('.rz-cell-data').forEach(cell => {
                if (!cell.hasAttribute('title')) {
                    const text = cell.textContent.trim();
                    if (text) {
                        cell.setAttribute('title', text);
                    }
                }
            });
        });
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
</body>
</html>
