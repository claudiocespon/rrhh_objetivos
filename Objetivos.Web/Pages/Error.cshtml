@page
@model Objetivos.Web.Pages.ErrorModel

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Error</title>
    <link href="~/css/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; }
        .error-container { padding: 2rem; max-width: 900px; margin: 0 auto; }
        .error-header { border-bottom: 3px solid #dc3545; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .exception-details { background: #f8f9fa; border-left: 4px solid #dc3545; padding: 1rem; margin: 1rem 0; border-radius: 4px; font-family: 'Courier New', monospace; }
        .stack-trace { background: #2d2d2d; color: #f8f8f2; padding: 1rem; border-radius: 4px; overflow-x: auto; font-size: 0.85rem; line-height: 1.4; }
        .dev-banner { background: #fff3cd; border: 1px solid #ffc107; padding: 1rem; border-radius: 4px; margin-bottom: 1.5rem; }
    </style>
</head>

<body>
    <div class="error-container">
        <div class="error-header">
            <h1 class="text-danger">❌ Error</h1>
            <h2 class="text-danger">Ocurrió un error al procesar su solicitud</h2>
        </div>

        @if (Model.ShowRequestId)
        {
            <p>
                <strong>ID de Solicitud:</strong> <code>@Model.RequestId</code>
            </p>
        }

        @if (Model.ShowException)
        {
            <div class="dev-banner">
                <strong>⚙️ Modo Desarrollo Habilitado</strong> — Los detalles de la excepción se muestran solo en desarrollo.
            </div>

            <div class="exception-details">
                <h4>📋 Detalles de la Excepción:</h4>
                <p><strong>Mensaje:</strong></p>
                <pre>@Model.ExceptionMessage</pre>

                @if (!string.IsNullOrEmpty(Model.ExceptionStackTrace))
                {
                    <p><strong>Stack Trace:</strong></p>
                    <pre class="stack-trace">@Model.ExceptionStackTrace</pre>
                }
            </div>

            <div class="mt-4">
                <a href="javascript:history.back()" class="btn btn-primary">← Volver</a>
                <a href="/" class="btn btn-secondary">🏠 Ir al Inicio</a>
            </div>
        }
        else
        {
            <p class="text-muted">Ha ocurrido un error inesperado. Por favor, intente nuevamente o contacte al equipo de soporte.</p>
            <div class="mt-4">
                <a href="javascript:history.back()" class="btn btn-primary">← Volver</a>
                <a href="/" class="btn btn-secondary">🏠 Ir al Inicio</a>
            </div>
        }
    </div>
</body>

</html>
