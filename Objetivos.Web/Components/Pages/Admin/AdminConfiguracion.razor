                    <RadzenDataGridColumn TItem="ConfiguracionPlataforma" Property="Clave" Title="Clave" Width="200px" />
                    <RadzenDataGridColumn TItem="ConfiguracionPlataforma" Property="Descripcion" Title="Descripción" Width="250px" />
                    <RadzenDataGridColumn TItem="ConfiguracionPlataforma" Property="Valor" Title="Valor" />
