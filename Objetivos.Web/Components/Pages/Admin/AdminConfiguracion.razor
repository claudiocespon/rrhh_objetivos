@page "/admin/configuracion"

@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject AdminPilarService AdminPilarService
@inject AdminSoftSkillService AdminSoftSkillService
@inject AdminAreaService AdminAreaService
@inject AdminEscalaValoracionService AdminEscalaService
@inject AdminEstadoService AdminEstadoService
@inject AdminConfiguracionPlatformaService AdminConfigService
@inject NotificationService NotificationService
@inject DialogService DialogService

<RadzenStack Gap="1.5rem">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Administración de Configuración</RadzenText>
    </RadzenStack>

    @if (loading)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Pilares Estratégicos">
                    @RenderPilares()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Soft Skills">
                    @RenderSoftSkills()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Escala de Valoración">
                    @RenderEscalas()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Estados Objetivo">
                    @RenderEstadosObjetivo()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Estados Evaluación">
                    @RenderEstadosEvaluacion()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Áreas">
                    @RenderAreas()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Configuraciones">
                    @RenderConfiguraciones()
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
</RadzenStack>

@code {
    List<Pilar> pilares = new();
    List<SoftSkill> softSkills = new();
    List<Area> areas = new();
    List<EscalaValoracion> escalas = new();
    List<EstadoObjetivoConfig> estadosObjetivo = new();
    List<EstadoEvaluacionConfig> estadosEvaluacion = new();
    List<ConfiguracionPlataforma> configuraciones = new();
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUser.InitializeAsync();
        if (!CurrentUser.EsAdmin)
        {
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }
        await LoadAllData();
    }

    async Task LoadAllData()
    {
        loading = true;
        pilares = await AdminPilarService.ObtenerTodosAsync();
        softSkills = await AdminSoftSkillService.ObtenerTodosAsync();
        areas = await AdminAreaService.ObtenerTodosAsync();
        escalas = await AdminEscalaService.ObtenerTodosAsync();
        estadosObjetivo = await AdminEstadoService.ObtenerEstadosObjetivoAsync();
        estadosEvaluacion = await AdminEstadoService.ObtenerEstadosEvaluacionAsync();
        configuraciones = await AdminConfigService.ObtenerTodosAsync();
        loading = false;
    }

    private RenderFragment RenderPilares() => __builder =>
    {
        <div class="pt-3">
            <RadzenButton Icon="add" Text="Agregar Pilar" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="@(() => OnAgregarPilar())" Style="margin-bottom: 1rem;" />
            <RadzenDataGrid Data="@pilares" TItem="Pilar" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                <Columns>
                    <RadzenDataGridColumn TItem="Pilar" Property="Nombre" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Pilar" Property="Descripcion" Title="Descripción" Width="250px" />
                    <RadzenDataGridColumn TItem="Pilar" Property="Orden" Title="Orden" Width="80px" />
                    <RadzenDataGridColumn TItem="Pilar" Title="Color" Width="100px">
                        <Template Context="p">
                            <div style="@($"background-color: {p.ColorHex}; width: 30px; height: 30px; border-radius: 4px;")"></div>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Pilar" Title="Área" Width="150px">
                        <Template Context="p">
                            @(p.Area?.Nombre ?? "Global")
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Pilar" Title="Oblig." Width="80px">
                        <Template Context="p">
                            <RadzenCheckBox @bind-Value="@p.EsObligatorio" Disabled="true" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Pilar" Title="Activo" Width="80px">
                        <Template Context="p">
                            <RadzenCheckBox @bind-Value="@p.Activo" Disabled="true" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Pilar" Filterable="false" Sortable="false" Width="150px">
                        <Template Context="p">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => OnEditarPilar(p))" />
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Small" Click="@(() => OnEliminarPilar(p.Id))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    };

