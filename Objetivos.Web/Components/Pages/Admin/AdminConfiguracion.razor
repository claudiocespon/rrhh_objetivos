                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SoftSkill" Filterable="false" Sortable="false" Width="150px">
                        <Template Context="s">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => OnEditarSoftSkill(s))" />
