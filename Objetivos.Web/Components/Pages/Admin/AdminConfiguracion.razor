                    <RadzenDataGridColumn TItem="SoftSkill" Property="Orden" Title="Orden" Width="80px" />
                    <RadzenDataGridColumn TItem="SoftSkill" Title="Activo" Width="80px">
                        <Template Context="s">
                            <RadzenCheckBox @bind-Value="@s.Activo" Disabled="true" />
