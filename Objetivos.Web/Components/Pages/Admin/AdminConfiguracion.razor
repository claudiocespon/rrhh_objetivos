            <RadzenDataGrid Data="@configuraciones" TItem="ConfiguracionPlataforma" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
