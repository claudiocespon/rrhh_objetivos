    };

    async Task OnAgregarPilar()
    {
        var result = await DialogService.OpenAsync<Dialogs.EditarPilarDialog>("Agregar Pilar",
            new Dictionary<string, object?> { { "Pilar", new Pilar() } },
            new DialogOptions { Width = "600px", Resizable = true, Draggable = true });

        if (result == true)
        {
            await LoadAllData();
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Pilar creado correctamente");
        }
    }

    async Task OnEditarPilar(Pilar p)
    {
        var result = await DialogService.OpenAsync<Dialogs.EditarPilarDialog>("Editar Pilar",
            new Dictionary<string, object?> { { "Pilar", p } },
            new DialogOptions { Width = "600px", Resizable = true, Draggable = true });

        if (result == true)
        {
            await LoadAllData();
        }
    }

    async Task OnEliminarPilar(int id)
    {
        var confirm = await DialogService.Confirm("¿Está seguro de que desea eliminar este pilar?", "Confirmar eliminación",
            new ConfirmOptions { OkButtonText = "Sí", CancelButtonText = "No" });

        if (confirm == true)
        {
            await AdminPilarService.EliminarAsync(id);
            await LoadAllData();
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Pilar eliminado correctamente");
        }
    }

