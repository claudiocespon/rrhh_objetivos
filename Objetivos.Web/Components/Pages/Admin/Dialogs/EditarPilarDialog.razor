@inject AdminPilarService AdminPilarService
@inject NotificationService NotificationService

<RadzenStack Gap="1rem">
    <RadzenTemplateForm TItem="Pilar" Data="@pilar" Submit="@OnSubmit">
        <RadzenStack Gap="1rem">
            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Nombre</RadzenText>
                    <RadzenTextBox @bind-Value="@pilar.Nombre" Style="width: 100%;" Name="Nombre" />
                    <RadzenRequiredValidator Component="Nombre" Text="El nombre es obligatorio" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Descripción</RadzenText>
                    <RadzenTextArea @bind-Value="@pilar.Descripcion" Style="width: 100%;" Name="Descripcion" Rows="3" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Color</RadzenText>
                    <input type="color" @bind="@pilar.ColorHex" style="width: 100%; height: 40px; cursor: pointer;" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Área (Dejar vacío para Global)</RadzenText>
                    <RadzenDropDown TValue="int?" @bind-Value="@pilar.AreaId" Data="@areas" TextProperty="Nombre" ValueProperty="Id" 
                                    Style="width: 100%;" AllowClear="true" Placeholder="Seleccione un área..." />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Obligatorio</RadzenText>
                    <div style="margin-top: 0.5rem;">
                        <RadzenCheckBox @bind-Value="@pilar.EsObligatorio" Name="Obligatorio" />
                        <label for="Obligatorio" style="margin-left: 0.5rem; vertical-align: middle;">Es Obligatorio</label>
                    </div>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <div style="margin-top: 0.5rem;">
                        <RadzenCheckBox @bind-Value="@pilar.Activo" Name="Activo" />
                        <label for="Activo" style="margin-left: 0.5rem; vertical-align: middle;">Activo</label>
                    </div>
                </RadzenColumn>
            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" Style="margin-top: 1rem;">
                <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" ButtonStyle="ButtonStyle.Primary" />
            </RadzenStack>
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenStack>

@code {
    [Parameter] public Pilar? Pilar { get; set; }
    [Inject] DialogService DialogService { get; set; } = null!;
    [Inject] AdminAreaService AdminAreaService { get; set; } = null!;

    private Pilar pilar = new();
    private List<Area> areas = new();

    protected override async Task OnInitializedAsync()
    {
        areas = await AdminAreaService.ObtenerTodosAsync();
        if (Pilar != null)
        {
            pilar = new()
            {
                Id = Pilar.Id,
                Nombre = Pilar.Nombre,
                Descripcion = Pilar.Descripcion,
                ColorHex = Pilar.ColorHex,
                Activo = Pilar.Activo,
                Orden = Pilar.Orden,
                AreaId = Pilar.AreaId,
                EsObligatorio = Pilar.EsObligatorio
            };
        }
    }

    private async Task OnSubmit()
    {
        bool esNuevo = pilar.Id == 0;
        bool success = esNuevo
            ? await AdminPilarService.CrearAsync(pilar)
            : await AdminPilarService.ActualizarAsync(pilar);

        if (success)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Éxito",
                esNuevo ? "Pilar creado correctamente" : "Pilar actualizado correctamente");
            DialogService.Close(true);
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error",
                esNuevo ? "No se pudo crear el pilar. Verificá que el nombre no esté repetido."
                        : "No se pudo actualizar el pilar.");
        }
    }
}
