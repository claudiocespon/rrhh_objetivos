@inject AdminPuestoService AdminPuestoService
@inject NotificationService NotificationService

<RadzenStack Gap="1rem">
    <RadzenTemplateForm TItem="Puesto" Data="@puesto" Submit="@OnSubmit">
        <RadzenStack Gap="1rem">
            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Nombre</RadzenText>
                    <RadzenTextBox @bind-Value="@puesto.Nombre" Style="width: 100%;" Name="Nombre" />
                    <RadzenRequiredValidator Component="Nombre" Text="El nombre es obligatorio" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Descripción</RadzenText>
                    <RadzenTextArea @bind-Value="@puesto.Descripcion" Style="width: 100%;" Name="Descripcion" Rows="3" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Estado</RadzenText>
                    <RadzenCheckBox @bind-Value="@puesto.Activo" Text="Activo" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" Style="margin-top: 1rem;">
                <RadzenButton ButtonType="ButtonType.Button" ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" ButtonStyle="ButtonStyle.Primary" />
            </RadzenStack>
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenStack>

@code {
    [Parameter] public Puesto? Puesto { get; set; }
    [Inject] DialogService DialogService { get; set; } = null!;

    private Puesto puesto = new();

    protected override void OnInitialized()
    {
        if (Puesto != null)
        {
            puesto = new()
            {
                Id = Puesto.Id,
                Nombre = Puesto.Nombre,
                Descripcion = Puesto.Descripcion,
                Activo = Puesto.Activo
            };
        }
    }

    private async Task OnSubmit()
    {
        bool esNuevo = puesto.Id == 0;
        bool success = await AdminPuestoService.SavePuestoAsync(puesto);

        if (success)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Éxito",
                esNuevo ? "Puesto creado correctamente" : "Puesto actualizado correctamente");
            DialogService.Close(true);
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error",
                esNuevo ? "No se pudo crear el puesto. Verificá que el nombre no esté repetido."
                        : "No se pudo actualizar el puesto.");
        }
    }
}
