@page "/login"
@layout LoginLayout
@inject AuthService AuthService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject NotificationService NotificationService
@inject IJSRuntime JS

<PageTitle>Iniciar Sesión - PQ-Talent</PageTitle>

<div class="login-container">
    <canvas id="login-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none;"></canvas>
    <div class="login-card">
        <div class="login-header">
            <img src="Pqtalent.png" class="login-logo-img" alt="PQ-Talent Logo" />
            <h1>Plataforma de gestión de Talento</h1>
            <p>Por favor ingrese su Usuario y Contraseña</p>
        </div>

        @if (!mostrarCambioPassword && !mostrarRecuperacion)
        {
            <!-- Login Form -->
            <RadzenTemplateForm TItem="LoginModel" Data="@loginModel" Submit="@OnLogin">
                <RadzenStack Gap="1.5rem">
                    <div>
                        <RadzenFormField Variant="Variant.Flat" class="login-input-field">
                            <Start>
                                <RadzenIcon Icon="person_outline" class="login-input-icon" />
                            </Start>
                            <ChildContent>
                                <RadzenTextBox @bind-Value="loginModel.Email" Name="Email" Placeholder="Usuario o Email" class="login-input" />
                            </ChildContent>
                        </RadzenFormField>
                        <RadzenRequiredValidator Component="Email" Text="Debe ingresar su email" Style="color: #ffb3b3; display: block; font-size: 0.8rem; margin-top: 4px;" />
                    </div>

                    <div>
                        <RadzenFormField Variant="Variant.Flat" class="login-input-field">
                            <Start>
                                <RadzenIcon Icon="lock_outline" class="login-input-icon" />
                            </Start>
                            <ChildContent>
                                @if(showPassword) {
                                    <RadzenTextBox @bind-Value="loginModel.Password" Name="Password" Placeholder="Contraseña" class="login-input" />
                                } else {
                                    <RadzenPassword @bind-Value="loginModel.Password" Name="Password" Placeholder="Contraseña" class="login-input" />
                                }
                            </ChildContent>
                            <End>
                                <RadzenIcon Icon="@(showPassword ? "visibility_off" : "visibility")" class="login-input-icon" Style="cursor:pointer; margin-right:0.75rem; font-size: 1.1rem; color: rgba(255,255,255,0.7) !important;" @onclick="() => showPassword = !showPassword" />
                            </End>
                        </RadzenFormField>
                        <RadzenRequiredValidator Component="Password" Text="Debe ingresar su contraseña" Style="color: #ffb3b3; display: block; font-size: 0.8rem; margin-top: 4px;" />
                        
                        <div style="text-align: center; margin-top: 10px;">
                            <span @onclick="@(() => mostrarRecuperacion = true)" class="login-forgot-link" style="cursor: pointer;">¿Olvidó su contraseña?</span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small" Style="background: rgba(255,0,0,0.1); border: 1px solid rgba(255,0,0,0.3); color: #ffb3b3;">
                            @errorMessage
                        </RadzenAlert>
                    }

                    <RadzenButton Text="Ingresar" ButtonType="ButtonType.Submit" class="login-btn"
                                  IsBusy="@isLoading" BusyText="Verificando..." Style="margin-top: 0.5rem;" />

                </RadzenStack>
            </RadzenTemplateForm>
        }
        else if (mostrarCambioPassword)
        {
            <!-- Change Password Form -->
            <RadzenStack Gap="1.5rem">
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small" Style="background: rgba(0,150,255,0.1); border: 1px solid rgba(0,150,255,0.3); color: #b3e0ff;">
                    Debe cambiar su contraseña antes de continuar. Mínimo 8 caracteres, incluyendo al menos una letra y un número.
                </RadzenAlert>

                <RadzenTemplateForm TItem="CambioPasswordModel" Data="@cambioModel" Submit="@OnCambiarPassword">
                    <RadzenStack Gap="1.5rem">
                        <div>
                            <RadzenFormField Variant="Variant.Flat" class="login-input-field">
                                <Start>
                                    <RadzenIcon Icon="lock_outline" class="login-input-icon" />
                                </Start>
                                <ChildContent>
                                    @if(showNuevaPassword) {
                                        <RadzenTextBox @bind-Value="cambioModel.NuevaPassword" Name="NuevaPassword" Placeholder="Nueva Contraseña" class="login-input" />
                                    } else {
                                        <RadzenPassword @bind-Value="cambioModel.NuevaPassword" Name="NuevaPassword" Placeholder="Nueva Contraseña" class="login-input" />
                                    }
                                </ChildContent>
                                <End>
                                    <RadzenIcon Icon="@(showNuevaPassword ? "visibility_off" : "visibility")" class="login-input-icon" Style="cursor:pointer; margin-right:0.75rem; font-size: 1.1rem; color: rgba(255,255,255,0.7) !important;" @onclick="() => showNuevaPassword = !showNuevaPassword" />
                                </End>
                            </RadzenFormField>
                            <RadzenRequiredValidator Component="NuevaPassword" Text="Debe ingresar una nueva contraseña" Style="color: #ffb3b3; display: block; font-size: 0.8rem; margin-top: 4px;" />
                        </div>

                        <div>
                            <RadzenFormField Variant="Variant.Flat" class="login-input-field">
                                <Start>
                                    <RadzenIcon Icon="lock_reset" class="login-input-icon" />
                                </Start>
                                <ChildContent>
                                    @if(showConfirmarPassword) {
                                        <RadzenTextBox @bind-Value="cambioModel.ConfirmarPassword" Name="ConfirmarPassword" Placeholder="Confirmar Contraseña" class="login-input" />
                                    } else {
                                        <RadzenPassword @bind-Value="cambioModel.ConfirmarPassword" Name="ConfirmarPassword" Placeholder="Confirmar Contraseña" class="login-input" />
                                    }
                                </ChildContent>
                                <End>
                                    <RadzenIcon Icon="@(showConfirmarPassword ? "visibility_off" : "visibility")" class="login-input-icon" Style="cursor:pointer; margin-right:0.75rem; font-size: 1.1rem; color: rgba(255,255,255,0.7) !important;" @onclick="() => showConfirmarPassword = !showConfirmarPassword" />
                                </End>
                            </RadzenFormField>
                            <RadzenRequiredValidator Component="ConfirmarPassword" Text="Debe confirmar la contraseña" Style="color: #ffb3b3; display: block; font-size: 0.8rem; margin-top: 4px;" />
                            <RadzenCompareValidator Value="@cambioModel.NuevaPassword" Component="ConfirmarPassword" Text="Las contraseñas no coinciden" Style="color: #ffb3b3; display: block; font-size: 0.8rem; margin-top: 4px;" />
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small" Style="background: rgba(255,0,0,0.1); border: 1px solid rgba(255,0,0,0.3); color: #ffb3b3;">
                                @errorMessage
                            </RadzenAlert>
                        }

                        <RadzenButton Text="Cambiar Contraseña" ButtonType="ButtonType.Submit" class="login-btn"
                                      IsBusy="@isLoading" BusyText="Guardando..." />
                    </RadzenStack>
                </RadzenTemplateForm>
            </RadzenStack>
        }
        else if (mostrarRecuperacion)
        {
            <!-- Password Recovery Info -->
            <RadzenStack Gap="1.5rem">
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Medium" Style="background: rgba(0,150,255,0.1); border: 1px solid rgba(0,150,255,0.3); color: #b3e0ff;">
                    Si olvidó su contraseña, por favor comuníquese con Recursos Humanos (RRHH) enviando un correo para solicitar el restablecimiento manual de la misma.
                </RadzenAlert>

                <div style="text-align: center; margin-top: 1rem;">
                    <RadzenLink Text="Volver al inicio de sesión" @onclick="@(() => { mostrarRecuperacion = false; errorMessage = null; })" class="login-forgot-link" />
                </div>
            </RadzenStack>
        }
    </div>
</div>

@code {
    LoginModel loginModel = new();
    CambioPasswordModel cambioModel = new();
    string? errorMessage;
    bool isLoading;
    bool mostrarCambioPassword;
    bool mostrarRecuperacion;
    bool showPassword;
    bool showNuevaPassword;
    bool showConfirmarPassword;
    int loginUserId;
    bool loginEsJefe;

    class LoginModel { public string Email { get; set; } = ""; public string Password { get; set; } = ""; }
    class CambioPasswordModel { public string NuevaPassword { get; set; } = ""; public string ConfirmarPassword { get; set; } = ""; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                await JS.InvokeVoidAsync("initLoginAnimation");
            } catch {
                // Ignore JS errors on prerender or if script isn't loaded
            }
        }
    }

    async Task OnLogin()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);
            if (!result.Exitoso)
            {
                errorMessage = result.MensajeError;
                return;
            }

            if (result.DebeCambiarPassword)
            {
                loginUserId = result.UsuarioId;
                loginEsJefe = result.EsJefe;
                mostrarCambioPassword = true;
                return;
            }

            await CurrentUser.SetUsuarioAsync(result.UsuarioId, result.NombreCompleto, result.Email, result.Rol, result.AreaId, result.EsJefe, false, result.EsSuperusuario);
            Nav.NavigateTo("dashboard");
        }
        finally { isLoading = false; }
    }

    async Task OnCambiarPassword()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            if (cambioModel.NuevaPassword != cambioModel.ConfirmarPassword)
            {
                errorMessage = "Las contraseñas no coinciden";
                return;
            }
            if (cambioModel.NuevaPassword.Length < 8 || !cambioModel.NuevaPassword.Any(char.IsLetter) || !cambioModel.NuevaPassword.Any(char.IsDigit))
            {
                errorMessage = "La contraseña debe tener al menos 8 caracteres, incluyendo una letra y un número";
                return;
            }

            var ok = await AuthService.CambiarPasswordAsync(loginUserId, loginEsJefe, cambioModel.NuevaPassword);
            if (!ok)
            {
                errorMessage = "Error al cambiar la contraseña o la contraseña no cumple con los requisitos";
                return;
            }

            // Re-login with new credentials
            var result = await AuthService.LoginAsync(loginModel.Email, cambioModel.NuevaPassword);
            if (result.Exitoso)
            {
                await CurrentUser.SetUsuarioAsync(result.UsuarioId, result.NombreCompleto, result.Email, result.Rol, result.AreaId, result.EsJefe, false, result.EsSuperusuario);
                NotificationService.Notify(NotificationSeverity.Success, "Contraseña actualizada", "Su contraseña ha sido cambiada exitosamente.");
                Nav.NavigateTo("dashboard");
            }
        }
        finally { isLoading = false; }
    }

    // Recuperación automatica ha sido removida en favor del contacto manual con RRHH.
}
