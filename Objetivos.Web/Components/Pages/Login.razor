@page "/login"
@layout LoginLayout
@inject AuthService AuthService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject NotificationService NotificationService

<PageTitle>Iniciar Sesión - PQ-Talent</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <img src="logo.png" class="login-logo-img" alt="PQ-Talent Logo" />
            <h1>PQ-Talent</h1>
            <p>Sistema de Gestión de Talento y Objetivos</p>
        </div>

        @if (!mostrarCambioPassword && !mostrarRecuperacion)
        {
            <!-- Login Form -->
            <RadzenTemplateForm TItem="LoginModel" Data="@loginModel" Submit="@OnLogin">
                <RadzenStack Gap="1.5rem">
                    <RadzenFormField Text="Email" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="loginModel.Email" Name="Email" Placeholder="nombre@permaquim.com" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="Email" Text="Debe ingresar su email" />
                    </RadzenFormField>

                    <RadzenFormField Text="Contraseña" Variant="Variant.Outlined">
                        <RadzenPassword @bind-Value="loginModel.Password" Name="Password" Placeholder="••••••••" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="Password" Text="Debe ingresar su contraseña" />
                    </RadzenFormField>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                            @errorMessage
                        </RadzenAlert>
                    }

                    <RadzenButton Text="Iniciar Sesión" ButtonType="ButtonType.Submit" Style="width: 100%;" 
                                  IsBusy="@isLoading" BusyText="Verificando..." />

                    <RadzenLink Text="¿Olvidaste tu contraseña?" Style="text-align: center; display: block;" 
                                @onclick="@(() => mostrarRecuperacion = true)" />
                </RadzenStack>
            </RadzenTemplateForm>
        }
        else if (mostrarCambioPassword)
        {
            <!-- Change Password Form -->
            <RadzenStack Gap="1rem">
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                    Debe cambiar su contraseña antes de continuar. Mínimo 8 caracteres, incluyendo al menos una letra y un número.
                </RadzenAlert>

                <RadzenTemplateForm TItem="CambioPasswordModel" Data="@cambioModel" Submit="@OnCambiarPassword">
                    <RadzenStack Gap="1.5rem">
                        <RadzenFormField Text="Nueva Contraseña" Variant="Variant.Outlined">
                            <RadzenPassword @bind-Value="cambioModel.NuevaPassword" Name="NuevaPassword" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="NuevaPassword" Text="Debe ingresar una nueva contraseña" />
                        </RadzenFormField>

                        <RadzenFormField Text="Confirmar Contraseña" Variant="Variant.Outlined">
                            <RadzenPassword @bind-Value="cambioModel.ConfirmarPassword" Name="ConfirmarPassword" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="ConfirmarPassword" Text="Debe confirmar la contraseña" />
                            <RadzenCompareValidator Value="@cambioModel.NuevaPassword" Component="ConfirmarPassword" Text="Las contraseñas no coinciden" />
                        </RadzenFormField>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                                @errorMessage
                            </RadzenAlert>
                        }

                        <RadzenButton Text="Cambiar Contraseña" ButtonType="ButtonType.Submit" Style="width: 100%;"
                                      IsBusy="@isLoading" BusyText="Guardando..." />
                    </RadzenStack>
                </RadzenTemplateForm>
            </RadzenStack>
        }
        else if (mostrarRecuperacion)
        {
            <!-- Password Recovery Form -->
            <RadzenStack Gap="1rem">
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                    Ingrese su email y se le generará una nueva contraseña provisional.
                </RadzenAlert>

                <RadzenTemplateForm TItem="RecuperacionModel" Data="@recuperacionModel" Submit="@OnRecuperar">
                    <RadzenStack Gap="1.5rem">
                        <RadzenFormField Text="Email" Variant="Variant.Outlined">
                            <RadzenTextBox @bind-Value="recuperacionModel.Email" Name="RecupEmail" Placeholder="nombre@permaquim.com" Style="width: 100%;" />
                            <RadzenRequiredValidator Component="RecupEmail" Text="Debe ingresar su email" />
                        </RadzenFormField>

                        @if (recuperacionExitosa)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                                Si el email existe en el sistema, recibirá instrucciones para restablecer su contraseña.
                            </RadzenAlert>
                        }

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" Size="AlertSize.Small">
                                @errorMessage
                            </RadzenAlert>
                        }

                        <RadzenButton Text="Recuperar Contraseña" ButtonType="ButtonType.Submit" Style="width: 100%;"
                                      IsBusy="@isLoading" BusyText="Procesando..." />

                        <RadzenLink Text="Volver al inicio de sesión" Style="text-align: center; display: block;"
                                    @onclick="@(() => { mostrarRecuperacion = false; errorMessage = null; recuperacionExitosa = false; })" />
                    </RadzenStack>
                </RadzenTemplateForm>
            </RadzenStack>
        }
    </div>
</div>

@code {
    LoginModel loginModel = new();
    CambioPasswordModel cambioModel = new();
    RecuperacionModel recuperacionModel = new();
    string? errorMessage;
    bool recuperacionExitosa;
    bool isLoading;
    bool mostrarCambioPassword;
    bool mostrarRecuperacion;
    int loginUserId;
    bool loginEsJefe;

    class LoginModel { public string Email { get; set; } = ""; public string Password { get; set; } = ""; }
    class CambioPasswordModel { public string NuevaPassword { get; set; } = ""; public string ConfirmarPassword { get; set; } = ""; }
    class RecuperacionModel { public string Email { get; set; } = ""; }

    async Task OnLogin()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);
            if (!result.Exitoso)
            {
                errorMessage = result.MensajeError;
                return;
            }

            if (result.DebeCambiarPassword)
            {
                loginUserId = result.UsuarioId;
                loginEsJefe = result.EsJefe;
                mostrarCambioPassword = true;
                return;
            }

            await CurrentUser.SetUsuarioAsync(result.UsuarioId, result.NombreCompleto, result.Email, result.Rol, result.AreaId, result.EsJefe, false, result.EsSuperusuario);
            Nav.NavigateTo("dashboard");
        }
        finally { isLoading = false; }
    }

    async Task OnCambiarPassword()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            if (cambioModel.NuevaPassword != cambioModel.ConfirmarPassword)
            {
                errorMessage = "Las contraseñas no coinciden";
                return;
            }
            if (cambioModel.NuevaPassword.Length < 8 || !cambioModel.NuevaPassword.Any(char.IsLetter) || !cambioModel.NuevaPassword.Any(char.IsDigit))
            {
                errorMessage = "La contraseña debe tener al menos 8 caracteres, incluyendo una letra y un número";
                return;
            }

            var ok = await AuthService.CambiarPasswordAsync(loginUserId, loginEsJefe, cambioModel.NuevaPassword);
            if (!ok)
            {
                errorMessage = "Error al cambiar la contraseña o la contraseña no cumple con los requisitos";
                return;
            }

            // Re-login with new credentials
            var result = await AuthService.LoginAsync(loginModel.Email, cambioModel.NuevaPassword);
            if (result.Exitoso)
            {
                await CurrentUser.SetUsuarioAsync(result.UsuarioId, result.NombreCompleto, result.Email, result.Rol, result.AreaId, result.EsJefe, false, result.EsSuperusuario);
                NotificationService.Notify(NotificationSeverity.Success, "Contraseña actualizada", "Su contraseña ha sido cambiada exitosamente.");
                Nav.NavigateTo("dashboard");
            }
        }
        finally { isLoading = false; }
    }

    async Task OnRecuperar()
    {
        isLoading = true;
        errorMessage = null;
        recuperacionExitosa = false;
        try
        {
            var success = await AuthService.RecuperarPasswordAsync(recuperacionModel.Email);
            if (!success)
            {
                // We show success even if email not found to avoid account enumeration
                recuperacionExitosa = true;
                return;
            }
            recuperacionExitosa = true;
        }
        finally { isLoading = false; }
    }
}

@* B-01: estilos de login movidos a wwwroot/css/site.css *@

