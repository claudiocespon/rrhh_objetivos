@inject RevisionService RevisionService
@inject AppDbContext Db
@inject DialogService DialogService

<RadzenTemplateForm TItem="FinalEvaluationModel" Data="@model" Submit="@OnSubmit">
    <RadzenStack Gap="1.5rem">
        @if (objetivo != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">
                Evaluación Final para: <b>@objetivo.Nombre</b>. El puntaje final será calculado automáticamente basado en el promedio ponderado de las revisiones.
            </RadzenAlert>
        }

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Resultado Final</RadzenText>
                <RadzenDropDown @bind-Value="@model.Resultado" Data="@resultados" 
                                Placeholder="Seleccione resultado final" Style="width: 100%;" Name="Resultado" />
                <RadzenRequiredValidator Component="Resultado" Text="El resultado final es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Comentario de Cierre (Jefe)</RadzenText>
                <RadzenTextArea @bind-Value="@model.Comentario" Style="width: 100%;" Rows="4" Name="Comentario" />
                <RadzenRequiredValidator Component="Comentario" Text="El comentario de cierre es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @if (errorMsg != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">@errorMsg</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Completar Evaluación Final" ButtonStyle="ButtonStyle.Success" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int ObjetivoId { get; set; }
    
    FinalEvaluationModel model = new();
    List<ResultadoEval> resultados = Enum.GetValues<ResultadoEval>().ToList();
    Objetivo? objetivo;
    string? errorMsg;

    protected override async Task OnInitializedAsync()
    {
        objetivo = await Db.Objetivos.FindAsync(ObjetivoId);
    }

    async Task OnSubmit()
    {
        errorMsg = null;
        var success = await RevisionService.CompletarEvaluacionFinalAsync(ObjetivoId, model.Comentario, model.Resultado!.Value);
        
        if (success)
        {
            DialogService.Close(true);
        }
        else
        {
            errorMsg = "No se pudo completar la evaluación final. Verifique que todas las revisiones cuatrimestrales estén cerradas y que el deadline haya pasado.";
        }
    }

    class FinalEvaluationModel
    {
        public ResultadoEval? Resultado { get; set; }
        public string Comentario { get; set; } = "";
    }
}
