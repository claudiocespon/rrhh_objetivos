@inject RevisionService RevisionService
@inject ObjetivoService ObjetivoService
@inject DialogService DialogService
@inject ConfiguracionService ConfigService

<RadzenTemplateForm TItem="FinalEvaluationModel" Data="@model" Submit="@OnSubmit">
    <RadzenStack Gap="1.5rem">
        @if (objetivo != null)
        {
            @if (resultadoFinalManual)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">
                    Evaluación Final para: <b>@objetivo.Nombre</b>. Ingrese manualmente la valoración final.
                </RadzenAlert>
            }
            else
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" ShowIcon="true">
                    Evaluación Final para: <b>@objetivo.Nombre</b>. La valoración final será calculada automáticamente basada en el promedio ponderado de las revisiones.
                </RadzenAlert>
            }

            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @objetivo.SoftSkill1.Nombre</RadzenText>
                    <EscalaSelector @bind-SelectedId="@model.SoftSkill1EscalaValoracionId" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill1Comentario" Placeholder="Comentario final sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @objetivo.SoftSkill2.Nombre</RadzenText>
                    <EscalaSelector @bind-SelectedId="@model.SoftSkill2EscalaValoracionId" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill2Comentario" Placeholder="Comentario final sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
            </RadzenRow>
        }

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Resultado Final</RadzenText>
                @if (resultadoFinalManual)
                {
                    <RadzenDropDown @bind-Value="@model.EscalaValoracionId" Data="@escalas" TextProperty="Etiqueta" ValueProperty="Id"
                                    Placeholder="Seleccione valoración final" Style="width: 100%;" Name="ResultadoEscala" />
                    <RadzenRequiredValidator Component="ResultadoEscala" Text="Debe seleccionar una valoración final" Style="position: absolute" />
                }
                else
                {
                    <RadzenDropDown @bind-Value="@model.Resultado" Data="@resultados"
                                    Placeholder="Seleccione resultado final" Style="width: 100%;" Name="Resultado" />
                    <RadzenRequiredValidator Component="Resultado" Text="El resultado final es obligatorio" Style="position: absolute" />
                }
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Comentario de Cierre (Jefe)</RadzenText>
                <RadzenTextArea @bind-Value="@model.Comentario" Style="width: 100%;" Rows="4" Name="Comentario" />
                <RadzenRequiredValidator Component="Comentario" Text="El comentario de cierre es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @if (errorMsg != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">@errorMsg</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Completar Evaluación Final" ButtonStyle="ButtonStyle.Success" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int ObjetivoId { get; set; }

    FinalEvaluationModel model = new();
    List<ResultadoEval> resultados = Enum.GetValues<ResultadoEval>().ToList();
    List<EscalaValoracion> escalas = new();
    Objetivo? objetivo;
    string? errorMsg;
    bool resultadoFinalManual = true;

    protected override async Task OnInitializedAsync()
    {
        objetivo = await ObjetivoService.GetByIdAsync(ObjetivoId);

        // Verificar si resultado final es manual
        resultadoFinalManual = await ConfigService.ObtenerConfiguracionBoolAsync("resultado_final_manual") ?? true;

        // Cargar escala de valoración si es manual
        if (resultadoFinalManual)
        {
            escalas = await ConfigService.ObtenerEscalasActivasAsync();
        }
    }

    async Task OnSubmit()
    {
        errorMsg = null;
        var success = await RevisionService.CompletarEvaluacionFinalAsync(
            ObjetivoId,
            model.Comentario,
            resultadoFinalManual ? null : model.Resultado,
            model.SoftSkill1EscalaValoracionId,
            model.SoftSkill1Comentario,
            model.SoftSkill2EscalaValoracionId,
            model.SoftSkill2Comentario,
            resultadoFinalManual ? model.EscalaValoracionId : null
        );

        if (success)
        {
            DialogService.Close(true);
        }
        else
        {
            errorMsg = "No se pudo completar la evaluación final. Verifique que todas las revisiones cuatrimestrales estén cerradas y que el deadline haya pasado.";
        }
    }

    class FinalEvaluationModel
    {
        public ResultadoEval? Resultado { get; set; }
        public int? EscalaValoracionId { get; set; }
        public string Comentario { get; set; } = "";

        public int? SoftSkill1EscalaValoracionId { get; set; }
        public string SoftSkill1Comentario { get; set; } = "";
        public int? SoftSkill2EscalaValoracionId { get; set; }
        public string SoftSkill2Comentario { get; set; } = "";
    }
}
