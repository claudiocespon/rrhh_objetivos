@page "/evaluacion"
@inject EvaluacionService EvaluacionService
@inject ICurrentUserService CurrentUser
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenText TextStyle="TextStyle.H4" Style="margin-bottom: 1.5rem;">Evaluaciones</RadzenText>

@if (loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (CurrentUser.EsJefe)
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Feedback Mitad de Año (Equipo)">
                    @RenderPendientes()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Feedback Mitad de Año Realizados (Equipo)">
                    @RenderRealizadas()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Evaluaciones Finales Pendientes">
                    @RenderFinalesPendientes()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Evaluaciones Finales Realizadas">
                    @RenderFinalesRealizadas()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Evaluaciones Recibidas">
                    @RenderRecibidas()
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
    else
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Feedback Mitad de Año">
                    @RenderRecibidas()
                </RadzenTabsItem>
                <RadzenTabsItem Text="Evaluaciones Finales">
                    @RenderFinalesRecibidas()
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
}

@code {
    List<RevisionCuatrimestral>? pendientes;
    List<RevisionCuatrimestral>? realizadas;
    List<Objetivo>? finalesPendientes;
    List<RevisionCuatrimestral>? recibidas;
    List<Objetivo>? finalesRealizadas;
    List<EvaluacionFinal>? finalesRecibidas;
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        loading = true;
        var data = await EvaluacionService.GetEvaluacionDataAsync(CurrentUser);
        
        pendientes = data.Pendientes;
        realizadas = data.Realizadas;
        finalesPendientes = data.FinalesPendientes;
        recibidas = data.Recibidas;
        finalesRealizadas = data.FinalesRealizadas;
        finalesRecibidas = data.FinalesRecibidas;

        loading = false;
    }

    async Task OnEvaluarClick(RevisionCuatrimestral rev)
    {
        var result = await DialogService.OpenAsync<EvaluarDialog>($"Evaluar: {rev.Periodo.ToString().Replace("FEEDBACK_MITAD_ANIO", "FEEDBACK MITAD DE AÑO")}",
            new Dictionary<string, object?> { { "RevisionId", rev.Id } },
            new DialogOptions { Width = "600px" });

        if (result == true)
        {
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Success, "Evaluación", "Revisión completada con éxito");
        }
    }

    async Task OnEvaluarFinalClick(Objetivo obj)
    {
        var result = await DialogService.OpenAsync<EvaluarFinalDialog>($"Evaluación Final: {obj.Nombre}",
            new Dictionary<string, object?> { { "ObjetivoId", obj.Id } },
            new DialogOptions { Width = "600px" });

        if (result == true)
        {
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Success, "Evaluación Final", "Evaluación final completada. El objetivo ha sido cerrado.");
        }
    }

    private RenderFragment RenderPendientes() => __builder =>
    {
        if (pendientes == null || !pendientes.Any())
        {
            <EmptyState Message="Todas las revisiones del período están completas ✅" />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@pendientes" TItem="RevisionCuatrimestral" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Usuario.Nombre" Title="Colaborador">
                            <Template Context="rev">
                                @rev.Objetivo.Usuario.Nombre @rev.Objetivo.Usuario.Apellido
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Objetivo.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {rev.Objetivo.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Title="Período" Width="150px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Periodo.ToString().Replace("FEEDBACK_MITAD_ANIO", "FEEDBACK MITAD DE AÑO")" BadgeStyle="BadgeStyle.Info" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Anio" Title="Año" Width="80px" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Context="rev" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="rev">
                                <RadzenButton Text="Evaluar" Icon="assignment_turned_in" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" 
                                              Click="@(() => OnEvaluarClick(rev))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderFinalesPendientes() => __builder =>
    {
        if (finalesPendientes == null || !finalesPendientes.Any())
        {
            <EmptyState Message="No hay objetivos pendientes de evaluación final." />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@finalesPendientes" TItem="Objetivo" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Usuario.Nombre" Title="Colaborador">
                            <Template Context="obj">
                                @obj.Usuario.Nombre @obj.Usuario.Apellido
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Objetivo" Property="Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="obj">
                                <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Deadline" Title="Vencimiento" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                        <RadzenDataGridColumn TItem="Objetivo" Context="obj" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="180px">
                            <Template Context="obj">
                                <RadzenButton Text="Evaluar Final" Icon="task_alt" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" 
                                              Click="@(() => OnEvaluarFinalClick(obj))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderRealizadas() => __builder =>
    {
        if (realizadas == null || !realizadas.Any())
        {
            <EmptyState Message="Aún no has realizado revisiones de mitad de año." />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@realizadas" TItem="RevisionCuatrimestral" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Usuario.Nombre" Title="Colaborador">
                            <Template Context="rev">
                                @rev.Objetivo.Usuario.Nombre @rev.Objetivo.Usuario.Apellido
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Objetivo.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {rev.Objetivo.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Title="Período" Width="150px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Periodo.ToString().Replace("FEEDBACK_MITAD_ANIO", "FEEDBACK MITAD DE AÑO")" BadgeStyle="BadgeStyle.Info" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Title="Valoración" Width="120px">
                            <Template Context="rev">
                                @(rev.EscalaValoracion?.Etiqueta ?? "-")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="ComentarioUsuario" Title="Resumen de Evaluación" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="FechaEvaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderRecibidas() => __builder =>
    {
        if (recibidas == null || !recibidas.Any())
        {
            <EmptyState Message="Aún no has recibido revisiones cuatrimestrales." />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@recibidas" TItem="RevisionCuatrimestral" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="Objetivo.Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Objetivo.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {rev.Objetivo.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Title="Período" Width="150px">
                            <Template Context="rev">
                                <RadzenBadge Text="@rev.Periodo.ToString().Replace("FEEDBACK_MITAD_ANIO", "FEEDBACK MITAD DE AÑO")" BadgeStyle="BadgeStyle.Success" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Title="Valoración" Width="120px">
                            <Template Context="rev">
                                @(rev.EscalaValoracion?.Etiqueta ?? "-")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="ComentarioUsuario" Title="Resumen de Evaluación" />
                        <RadzenDataGridColumn TItem="RevisionCuatrimestral" Property="FechaEvaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderFinalesRealizadas() => __builder =>
    {
        if (finalesRealizadas == null || !finalesRealizadas.Any())
        {
            <EmptyState Message="Aún no has realizado evaluaciones finales." />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@finalesRealizadas" TItem="Objetivo" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Usuario.Nombre" Title="Colaborador">
                            <Template Context="obj">
                                @obj.Usuario.Nombre @obj.Usuario.Apellido
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Objetivo" Property="Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="obj">
                                <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Title="Valoración Final" Width="150px">
                            <Template Context="obj">
                                @(obj.EvaluacionFinal?.EscalaValoracionFinal?.Etiqueta ?? "-")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Property="EvaluacionFinal.FechaEvaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderFinalesRecibidas() => __builder =>
    {
        if (finalesRecibidas == null || !finalesRecibidas.Any())
        {
            <EmptyState Message="Aún no has recibido evaluaciones finales." />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@finalesRecibidas" TItem="EvaluacionFinal" AllowPaging="true" PageSize="10" Responsive="true" AllowFiltering="true" FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                    <Columns>
                        <RadzenDataGridColumn TItem="EvaluacionFinal" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="EvaluacionFinal" Property="Objetivo.Pilar.Nombre" Title="Pilar" Width="180px">
                            <Template Context="ef">
                                <RadzenBadge Text="@ef.Objetivo.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {ef.Objetivo.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="EvaluacionFinal" Title="Valoración" Width="120px">
                            <Template Context="ef">
                                <RadzenBadge Text="@(ef.EscalaValoracionFinal?.Etiqueta ?? "-")" BadgeStyle="BadgeStyle.Primary" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="EvaluacionFinal" Property="ComentarioUsuario" Title="Resumen Final" />
                        <RadzenDataGridColumn TItem="EvaluacionFinal" Property="FechaEvaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };
}
