@inject RevisionService RevisionService
@inject DialogService DialogService

<RadzenTemplateForm TItem="EvaluationModel" Data="@model" Submit="@OnSubmit">
    <RadzenStack Gap="1.5rem">
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Valoración General (1-5 estrellas)</RadzenText>
                <RadzenRating @bind-Value="@model.Valoracion" Stars="5" Name="Valoracion" />
                <RadzenRequiredValidator Component="Valoracion" Text="Debe calificar con al menos 1 estrella" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @if (revision?.Objetivo != null)
        {
            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @revision.Objetivo.SoftSkill1.Nombre</RadzenText>
                    <RadzenRating @bind-Value="@model.SoftSkill1Valoracion" Stars="5" Name="SS1Valoracion" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill1Comentario" Placeholder="Comentario sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @revision.Objetivo.SoftSkill2.Nombre</RadzenText>
                    <RadzenRating @bind-Value="@model.SoftSkill2Valoracion" Stars="5" Name="SS2Valoracion" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill2Comentario" Placeholder="Comentario sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
            </RadzenRow>
        }

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Resultado</RadzenText>
                <RadzenDropDown @bind-Value="@model.Resultado" Data="@resultados" 
                                Placeholder="Seleccione resultado" Style="width: 100%;" Name="Resultado" />
                <RadzenRequiredValidator Component="Resultado" Text="El resultado es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Comentario del Jefe</RadzenText>
                <RadzenTextArea @bind-Value="@model.Comentario" Style="width: 100%;" Rows="3" Name="Comentario" />
                <RadzenRequiredValidator Component="Comentario" Text="El comentario es obligatorio" Style="position: absolute" />
                <RadzenLengthValidator Component="Comentario" Min="10" Text="El comentario debe tener al menos 10 caracteres" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Evidencias Verificadas</RadzenText>
                <RadzenCheckBoxList @bind-Value="@model.EvidenciasSeleccionadas" TValue="string" Orientation="Orientation.Vertical" Name="Evidencias">
                    <Items>
                        @foreach (var ev in evidenciasDisponibles)
                        {
                            <RadzenCheckBoxListItem Text="@ev" Value="@ev" />
                        }
                    </Items>
                </RadzenCheckBoxList>
                @if (submitted && RequiereEvidencia() && !model.EvidenciasSeleccionadas.Any())
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-danger)">Debe marcar al menos una evidencia para esta valoración</RadzenText>
                }
            </RadzenColumn>
        </RadzenRow>

        @if (errorMsg != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">@errorMsg</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Confirmar Evaluación" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int RevisionId { get; set; }
    
    RevisionCuatrimestral? revision;
    EvaluationModel model = new();
    List<ResultadoEval> resultados = Enum.GetValues<ResultadoEval>().ToList();
    List<string> evidenciasDisponibles = new() { "Reporte de avance", "Documentación técnica", "Presentación de resultados", "Feedback de pares", "Métricas de sistema" };
    string? errorMsg;
    bool submitted = false;

    protected override async Task OnInitializedAsync()
    {
        revision = await RevisionService.GetRevisionDetalleAsync(RevisionId);
    }

    bool RequiereEvidencia()
    {
        // VAL-10: Solo obligatorio si valoración <= 2 o == 5
        return model.Valoracion <= 2 || model.Valoracion == 5;
    }

    async Task OnSubmit()
    {
        submitted = true;
        errorMsg = null;

        if (RequiereEvidencia() && !model.EvidenciasSeleccionadas.Any())
        {
            return;
        }

        var success = await RevisionService.CompletarRevisionAsync(
            RevisionId,
            model.Valoracion,
            model.Comentario,
            model.Resultado!.Value,
            model.EvidenciasSeleccionadas.ToList(),
            model.SoftSkill1Valoracion,
            model.SoftSkill1Comentario,
            model.SoftSkill2Valoracion,
            model.SoftSkill2Comentario
        );
        
        if (success)
        {
            DialogService.Close(true);
        }
        else
        {
            errorMsg = "No se pudo completar la revisión. Verifique que el período anterior esté cerrado.";
        }
    }

    class EvaluationModel
    {
        public int Valoracion { get; set; } = 0;
        public ResultadoEval? Resultado { get; set; }
        public string Comentario { get; set; } = "";
        public IEnumerable<string> EvidenciasSeleccionadas { get; set; } = new List<string>();

        public int SoftSkill1Valoracion { get; set; }
        public string SoftSkill1Comentario { get; set; } = "";
        public int SoftSkill2Valoracion { get; set; }
        public string SoftSkill2Comentario { get; set; } = "";
    }
}
