@inject RevisionService RevisionService
@inject DialogService DialogService
@inject ConfiguracionService ConfigService

<RadzenTemplateForm TItem="EvaluationModel" Data="@model" Submit="@OnSubmit">
    <RadzenStack Gap="1.5rem">
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Valoración General</RadzenText>
                <EscalaSelector @bind-SelectedId="@model.EscalaValoracionId" />
                <RadzenRequiredValidator Component="Valoracion" Text="Debe seleccionar una valoración" DefaultValue="0" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @if (revision?.Objetivo != null)
        {
            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @revision.Objetivo.SoftSkill1.Nombre</RadzenText>
                    <EscalaSelector @bind-SelectedId="@model.SoftSkill1EscalaValoracionId" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill1Comentario" Placeholder="Comentario sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Habilidad: @revision.Objetivo.SoftSkill2.Nombre</RadzenText>
                    <EscalaSelector @bind-SelectedId="@model.SoftSkill2EscalaValoracionId" />
                    <RadzenTextArea @bind-Value="@model.SoftSkill2Comentario" Placeholder="Comentario sobre esta habilidad..." Style="width: 100%; margin-top: 0.5rem;" Rows="2" />
                </RadzenColumn>
            </RadzenRow>
        }

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Comentario del Jefe</RadzenText>
                <RadzenTextArea @bind-Value="@model.Comentario" Style="width: 100%;" Rows="3" Name="Comentario" />
                <RadzenRequiredValidator Component="Comentario" Text="El comentario es obligatorio" Style="position: absolute" />
                <RadzenLengthValidator Component="Comentario" Min="10" Text="El comentario debe tener al menos 10 caracteres" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @* M-10: Evidencias seleccionables desde la bitácora del objetivo *@
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2">Evidencias respaldatorias</RadzenText>
                @if (bitacora == null)
                {
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="height: 4px;" />
                }
                else if (!bitacora.Any())
                {
                    <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter" ShowIcon="true" AllowClose="false">
                        El empleado aún no ha cargado entradas de bitácora para este objetivo.
                    </RadzenAlert>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.7;">Marque las entradas de bitácora que respaldan esta valoración</RadzenText>
                    <RadzenStack Gap="0.4rem" Style="margin-top: 0.5rem; max-height: 200px; overflow-y: auto;">
                        @foreach (var entrada in bitacora)
                        {
                            var clave = $"{entrada.Fecha:dd/MM/yyyy} — {(entrada.Texto.Length > 100 ? entrada.Texto[..100] + "…" : entrada.Texto)}";
                            <RadzenCheckBox @bind-Value="@(evidenciasSeleccionadas[entrada.Id])"
                                            Name="@($"ev_{entrada.Id}")" />
                            <RadzenLabel Component="@($"ev_{entrada.Id}")" Text="@clave" Style="margin-left: 0.5rem; font-size: 0.85rem;" />
                        }
                    </RadzenStack>
                }
            </RadzenColumn>
        </RadzenRow>

        @if (errorMsg != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">@errorMsg</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Confirmar Evaluación" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int RevisionId { get; set; }

    RevisionCuatrimestral? revision;
    List<BitacoraEntrada>? bitacora;
    Dictionary<int, bool> evidenciasSeleccionadas = new();
    EvaluationModel model = new();
    List<ResultadoEval> resultados = Enum.GetValues<ResultadoEval>().ToList();
    string? errorMsg;
    bool submitted = false;

    protected override async Task OnInitializedAsync()
    {
        revision = await RevisionService.GetRevisionDetalleAsync(RevisionId);

        if (revision?.Objetivo != null)
        {
            // M-10: Cargar entradas de bitácora del objetivo
            bitacora = await RevisionService.GetBitacoraDelObjetivoAsync(revision.ObjetivoId);
            foreach (var entrada in bitacora)
                evidenciasSeleccionadas[entrada.Id] = false;
        }
        else
        {
            bitacora = new List<BitacoraEntrada>();
        }
    }

    async Task OnSubmit()
    {
        submitted = true;
        errorMsg = null;

        // Mapear evidencias seleccionadas a strings (formato fecha + texto)
        var evidenciasMarcadas = new List<string>();
        if (bitacora != null)
        {
            foreach (var entrada in bitacora.Where(e => evidenciasSeleccionadas.GetValueOrDefault(e.Id)))
            {
                evidenciasMarcadas.Add($"{entrada.Fecha:dd/MM/yyyy} — {entrada.Texto}");
            }
        }

        var success = await RevisionService.CompletarRevisionAsync(
            RevisionId,
            model.EscalaValoracionId,
            model.Comentario,
            null,
            evidenciasMarcadas,
            model.SoftSkill1EscalaValoracionId,
            model.SoftSkill1Comentario,
            model.SoftSkill2EscalaValoracionId,
            model.SoftSkill2Comentario
        );

        if (success)
        {
            DialogService.Close(true);
        }
        else
        {
            errorMsg = "No se pudo completar la revisión. Verifique que el período anterior esté cerrado.";
        }
    }

    class EvaluationModel
    {
        public int? EscalaValoracionId { get; set; }
        public ResultadoEval? Resultado { get; set; }
        public string Comentario { get; set; } = "";

        public int? SoftSkill1EscalaValoracionId { get; set; }
        public string SoftSkill1Comentario { get; set; } = "";
        public int? SoftSkill2EscalaValoracionId { get; set; }
        public string SoftSkill2Comentario { get; set; } = "";
    }
}
