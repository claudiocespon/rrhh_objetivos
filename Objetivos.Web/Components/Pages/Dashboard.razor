@page "/dashboard"
@inject DashboardService DashboardService
@inject CalendarioService CalendarioService
@inject ICurrentUserService CurrentUser
@inject NavigationManager NavigationManager

<style>
    .kpi-card {
        flex: 1;
        min-width: 200px;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
</style>

<RadzenText TextStyle="TextStyle.H4" Style="margin-bottom: 1.5rem;">Dashboard</RadzenText>

@if (roleData == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (roleData.Equipo != null && roleData.Personal != null)
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Mi Equipo / Área">
                    @RenderDashboard(roleData.Equipo, "Estado de Objetivos del Equipo", "seguimientos", "evaluacion")
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Objetivos">
                    @RenderDashboard(roleData.Personal, "Mi Estado Personal", "objetivos", "autoevaluacion")
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
    else if (roleData.Equipo != null)
    {
        @RenderDashboard(roleData.Equipo, "Estado de Objetivos del Equipo", "seguimientos", "evaluacion")
    }
    else if (roleData.Personal != null)
    {
        @RenderDashboard(roleData.Personal, "Mi Estado Personal", "objetivos", "autoevaluacion")
    }
    else
    {
        <EmptyState Message="Sin datos de dashboard disponibles." />
    }
}

@code {
    RoleDashboardData? roleData;
    List<ProximoEvento> proximosEventos = new();

    protected override async Task OnInitializedAsync()
    {
        roleData = await DashboardService.GetDashboardDataAsync();
        proximosEventos = await CalendarioService.GetProximosEventosAsync(CurrentUser);
    }

    private RenderFragment RenderDashboard(DashboardData data, string title, string pathGeneral, string pathRevision) => __builder =>
    {
        // M-01: Mostrar distribución real de estados — "Vencen Pronto" es un subconjunto
        // de ACTIVO, no un estado; se muestra en su KPI card separado, no en el donut.
        var donutData = new List<DonutItem>
        {
            new DonutItem { Estado = "En Curso", Cantidad = data.EnCurso },
            new DonutItem { Estado = "En Riesgo", Cantidad = data.EnRiesgo },
            new DonutItem { Estado = "Completados", Cantidad = data.Completados }
        }.Where(d => d.Cantidad > 0).ToList();

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem" Style="margin-bottom: 2rem; flex-wrap: wrap;">
            <RadzenCard class="kpi-card" Style="background-color: var(--rz-primary); color: white;" @onclick="@(() => NavigationManager.NavigateTo(pathGeneral))">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="assignment" Style="font-size: 2.5rem; opacity: 0.8;" />
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; text-align: center;">@data.TotalObjetivos</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: white; opacity: 0.8; margin: 0; text-align: center;">Total Objetivos</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard class="kpi-card" Style="background-color: var(--rz-info); color: white;" @onclick="@(() => NavigationManager.NavigateTo(pathGeneral))">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="trending_up" Style="font-size: 2.5rem; opacity: 0.8;" />
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; text-align: center;">@data.EnCurso</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: white; opacity: 0.8; margin: 0; text-align: center;">En Curso</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard class="kpi-card" Style="background-color: var(--rz-warning); color: white;" @onclick="@(() => NavigationManager.NavigateTo(pathGeneral))">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="schedule" Style="font-size: 2.5rem; opacity: 0.8;" />
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; text-align: center;">@data.VencenPronto</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: white; opacity: 0.8; margin: 0; text-align: center;">Vencen Pronto</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard class="kpi-card" Style="background-color: var(--rz-danger); color: white;" @onclick="@(() => NavigationManager.NavigateTo(pathRevision))">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="rule" Style="font-size: 2.5rem; opacity: 0.8;" />
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; text-align: center;">@data.PendientesRevision</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: white; opacity: 0.8; margin: 0; text-align: center;">Pendientes Revisión</RadzenText>
                </RadzenStack>
            </RadzenCard>
            <RadzenCard class="kpi-card" Style="background-color: var(--rz-success); color: white;" @onclick="@(() => NavigationManager.NavigateTo(pathGeneral))">
                <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="verified" Style="font-size: 2.5rem; opacity: 0.8;" />
                    <RadzenText TextStyle="TextStyle.H5" Style="color: white; margin: 0; text-align: center;">@data.EvaluacionesFinalizadas</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: white; opacity: 0.8; margin: 0; text-align: center;">Evaluados Finales</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Style="margin-top: 2rem;">
            <RadzenCard Style="flex: 2;">
                <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 1rem;">@title</RadzenText>
                @if (data.TotalObjetivos == 0)
                {
                    <EmptyState Message="No hay objetivos creados aún" />
                }
                else
                {
                    <RadzenChart>
                        <RadzenDonutSeries Data="@donutData" CategoryProperty="Estado" ValueProperty="Cantidad" Title="Objetivos">
                            <ChildContent>
                                <RadzenSeriesDataLabels Visible="true" />
                            </ChildContent>
                        </RadzenDonutSeries>
                    </RadzenChart>
                }
            </RadzenCard>
            <RadzenCard Style="flex: 1;">
                <RadzenStack Gap="0.75rem">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 0.5rem;">Próximos Eventos</RadzenText>
                    @if (!proximosEventos.Any())
                    {
                        <RadzenStack AlignItems="AlignItems.Center" Style="padding: 1.5rem 0; opacity: 0.6;">
                            <RadzenIcon Icon="event_available" Style="font-size: 2rem;" />
                            <RadzenText TextStyle="TextStyle.Caption">Sin eventos próximos</RadzenText>
                        </RadzenStack>
                    }
                    else
                    {
                        @foreach (var ev in proximosEventos)
                        {
                            <RadzenCard Style="@($"border-left: 4px solid {GetEventoColor(ev.Tipo)}; padding: 0.6rem 0.85rem;")">
                                <RadzenStack Gap="0.1rem">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.4rem">
                                        <RadzenIcon Icon="@GetEventoIcono(ev.Tipo)" Style="@($"color: {GetEventoColor(ev.Tipo)}; font-size: 1rem;")" />
                                        <RadzenText TextStyle="TextStyle.Body2" Style="margin: 0; font-weight: 600; white-space: normal; word-break: break-word;">@ev.Titulo</RadzenText>
                                    </RadzenStack>
                                    @if (!string.IsNullOrEmpty(ev.Subtitulo))
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; opacity: 0.7;">@ev.Subtitulo</RadzenText>
                                    }
                                    <RadzenText TextStyle="TextStyle.Caption" Style="@($"margin: 0; color: {GetEventoColor(ev.Tipo)};")">
                                        @ev.Fecha.ToString("dd/MM/yyyy")
                                        @if (ev.EsVencido)
                                        {
                                            <span> · VENCIDO</span>
                                        }
                                        else if (ev.DiasFaltantes == 0)
                                        {
                                            <span> · HOY</span>
                                        }
                                        else
                                        {
                                            <span> · en @ev.DiasFaltantes día(s)</span>
                                        }
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenCard>
                        }
                    }
                </RadzenStack>
            </RadzenCard>
        </RadzenStack>
    };

    string GetEventoColor(string tipo) => tipo switch
    {
        "DEADLINE"            => "var(--rz-danger)",
        "REVISION_PENDIENTE"  => "var(--rz-warning)",
        "EVALUACION_FINAL"    => "var(--rz-info)",
        _                     => "var(--rz-primary)"
    };

    string GetEventoIcono(string tipo) => tipo switch
    {
        "DEADLINE"            => "flag",
        "REVISION_PENDIENTE"  => "rate_review",
        "EVALUACION_FINAL"    => "verified",
        _                     => "event"
    };

    class DonutItem
    {
        public string Estado { get; set; } = "";
        public int Cantidad { get; set; }
    }
}
