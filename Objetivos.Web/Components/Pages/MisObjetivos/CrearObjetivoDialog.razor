@inject ObjetivoService ObjetivoService
@inject ICurrentUserService CurrentUser
@inject NotificationService NotificationService
@inject IDbContextFactory<AppDbContext> DbFactory
@inject DialogService DialogService
@inject ValidacionObjetivoService ValidacionService
@inject ConfiguracionService ConfigService

<RadzenTemplateForm TItem="Objetivo" Data="@objetivo" Submit="@OnSubmit">
    <RadzenStack Gap="1rem">
        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Colaborador</RadzenText>
                <RadzenDropDown @bind-Value="@objetivo.EmpleadoId" Data="@empleados" TextProperty="NombreCompleto" ValueProperty="Id" 
                                Style="width: 100%;" Name="Empleado" 
                                AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                Change="@OnEmpleadoChanged" />
                <RadzenRequiredValidator Component="Empleado" Text="Este campo es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="8">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Pilar Estratégico</RadzenText>
                <RadzenDropDown @bind-Value="@objetivo.PilarId" Data="@pilaresConConfig" TextProperty="Pilar.Nombre" ValueProperty="Pilar.Id"
                                Style="width: 100%;" Name="Pilar" Change="@OnPilarChanged">
                    <Template Context="pcc">
                        @pcc.Pilar.Nombre @(pcc.EsObligatorio ? "(Obligatorio)" : "")
                    </Template>
                </RadzenDropDown>
                <RadzenRequiredValidator Component="Pilar" Text="Este campo es obligatorio" Style="position: absolute" />
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Ponderación (%)</RadzenText>
                <RadzenNumeric @bind-Value="@objetivo.PorcentajePilar" Min="0" Max="100" Step="5" Style="width: 100%;" Name="Porcentaje" />
                <RadzenRangeValidator Component="Porcentaje" Min="0" Max="100" Text="El porcentaje debe estar entre 0 y 100" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Nombre del Objetivo</RadzenText>
                <RadzenTextBox @bind-Value="@objetivo.Nombre" Style="width: 100%;" Name="Nombre" />
                <RadzenRequiredValidator Component="Nombre" Text="Este campo es obligatorio" Style="position: absolute" />
                <RadzenLengthValidator Component="Nombre" Min="5" Max="100" Text="El nombre debe tener entre 5 y 100 caracteres" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Descripción</RadzenText>
                <RadzenTextArea @bind-Value="@objetivo.Descripcion" Style="width: 100%;" Name="Descripcion" Rows="3" />
                <RadzenRequiredValidator Component="Descripcion" Text="Este campo es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Fecha de Cierre (Deadline)</RadzenText>
                <RadzenDatePicker @bind-Value="@objetivo.Deadline" Style="width: 100%;" Name="Deadline" DateFormat="dd/MM/yyyy" Min="@DateTime.Today" />
                <RadzenRequiredValidator Component="Deadline" Text="Este campo es obligatorio" Style="position: absolute" />
                @if (objetivo.Deadline <= DateTime.Today && objetivo.Deadline != default)
                {
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-danger)">La fecha de cierre debe ser posterior a hoy</RadzenText>
                }
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Soft Skill 1</RadzenText>
                <RadzenDropDown @bind-Value="@objetivo.SoftSkill1Id" Data="@softSkills" TextProperty="Nombre" ValueProperty="Id"
                                Style="width: 100%;" Name="SS1" />
                <RadzenRequiredValidator Component="SS1" Text="Este campo es obligatorio" Style="position: absolute" />
            </RadzenColumn>
            <RadzenColumn Size="6">
                <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Soft Skill 2</RadzenText>
                <RadzenDropDown @bind-Value="@objetivo.SoftSkill2Id" Data="@softSkills" TextProperty="Nombre" ValueProperty="Id"
                                Style="width: 100%;" Name="SS2" />
                <RadzenRequiredValidator Component="SS2" Text="Este campo es obligatorio" Style="position: absolute" />
            </RadzenColumn>
        </RadzenRow>

        @if (objetivoAreaHabilitado)
        {
            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Objetivo Específico por Área (Opcional)</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.7;">Configure si este objetivo está dirigido a una área específica</RadzenText>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow>
                <RadzenColumn Size="8">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Área Específica</RadzenText>
                    <RadzenDropDown @bind-Value="@objetivo.AreaEspecificaId" Data="@areas" TextProperty="Nombre" ValueProperty="Id"
                                    Style="width: 100%;" Name="AreaEspecifica" AllowClear="true" Placeholder="Seleccione un área..." />
                </RadzenColumn>
                <RadzenColumn Size="4">
                    <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Ponderación Área (%)</RadzenText>
                    <RadzenNumeric @bind-Value="@objetivo.PorcentajeArea" Min="0" Max="100" Step="5" Style="width: 100%;" Name="PorcentajeArea" />
                </RadzenColumn>
            </RadzenRow>
        }

        @if (errorMsg != null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">
                @errorMsg
            </RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" Style="margin-top: 1rem;">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancelar" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Crear Objetivo" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    Objetivo objetivo = new() { Deadline = DateTime.Today.AddMonths(6) };
    List<EmpleadoItem> empleados = new();
    List<PilarConConfig> pilaresConConfig = new();
    List<SoftSkill> softSkills = new();
    List<Area> areas = new();
    bool objetivoAreaHabilitado = false;
    string? errorMsg;

    protected override async Task OnInitializedAsync()
    {
        // VAL-JEFE: Verificar si jefe puede crear objetivos
        bool jefePermitido = await ConfigService.ObtenerConfiguracionBoolAsync("jefe_puede_crear_objetivos") ?? false;
        if (CurrentUser.EsJefe && !jefePermitido
            && CurrentUser.Rol != "RRHH"
            && CurrentUser.Rol != "DIRECTOR_GENERAL")
        {
            errorMsg = "Su rol no tiene permiso para crear objetivos. Contacte al área de RRHH.";
            return;
        }

        using var db = await DbFactory.CreateDbContextAsync();

        softSkills = await db.SoftSkills.Where(s => s.Activo).ToListAsync();
        areas = await db.Areas.Where(a => a.Activo).ToListAsync();

        // Verificar si objetivo por área está habilitado
        objetivoAreaHabilitado = await ConfigService.ObtenerConfiguracionBoolAsync("objetivo_area_habilitado") ?? false;

        IQueryable<Empleado> query = db.Empleados;

        bool canSeeAll = CurrentUser.Rol == "RRHH" || CurrentUser.Rol == "DIRECTOR_GENERAL" || CurrentUser.EsSuperusuario;

        if (canSeeAll)
        {
            // RRHH, Director General, Superusuario → all employees
        }
        else if (CurrentUser.Rol == "DIRECTOR")
        {
            // Directors see all employees in their area
            query = query.Where(e => e.AreaId == CurrentUser.AreaId);
        }
        else
        {
            // Standard bosses see only direct subordinates
            query = query.Where(e => e.JefeId == CurrentUser.UsuarioId);
        }

        var rawEmpleados = await query.OrderBy(e => e.Apellido).ToListAsync();
        if (rawEmpleados.Count == 0)
        {
            errorMsg = "No hay empleados asignados a su área. Contacte a RRHH.";
        }
        empleados = rawEmpleados.Select(e => new EmpleadoItem { 
            Id = e.Id, 
            NombreCompleto = string.IsNullOrWhiteSpace(e.Apellido) ? e.Nombre : $"{e.Apellido}, {e.Nombre}" 
        }).ToList();

        if (objetivo.EmpleadoId > 0 || (empleados.Count == 1 && (objetivo.EmpleadoId = empleados[0].Id) > 0))
        {
            await OnEmpleadoChanged();
        }
    }

    async Task OnEmpleadoChanged()
    {
        if (objetivo.EmpleadoId > 0)
        {
            pilaresConConfig = await ObjetivoService.GetPilaresDisponiblesAsync(objetivo.EmpleadoId);
            StateHasChanged();
        }
    }

    void OnPilarChanged()
    {
        // No longer suggesting weight from Pillar as PesoPorcentual was removed
    }

    async Task OnSubmit()
    {
        errorMsg = null;

        // VAL-03
        if (objetivo.SoftSkill1Id == objetivo.SoftSkill2Id)
        {
            errorMsg = "Las dos soft skills deben ser diferentes";
            return;
        }

        // VAL-04
        if (objetivo.Deadline <= DateTime.Today)
        {
            errorMsg = "La fecha de cierre debe ser posterior a hoy";
            return;
        }

        // VAL-06: Validar que la suma total de todos los objetivos no exceda el 100%
        using var dbVal = await DbFactory.CreateDbContextAsync();
        var objetivosExistentes = await dbVal.Objetivos
            .Where(o => o.EmpleadoId == objetivo.EmpleadoId && o.Anio == DateTime.Now.Year && o.Estado != EstadoObjetivo.CANCELADO)
            .ToListAsync();

        if (!ValidacionService.ValidarNuevoPeso(objetivosExistentes, objetivo.PorcentajePilar))
        {
            var sumaActual = objetivosExistentes.Sum(o => o.PorcentajePilar);
            errorMsg = $"La suma total de pesos no puede exceder el 100%. Actualmente suma {sumaActual}%. Estás intentando agregar {objetivo.PorcentajePilar}%.";
            return;
        }

        // VAL-05: Límite de 10 objetivos
        if (objetivosExistentes.Count >= 10)
        {
            errorMsg = "El empleado ya ha alcanzado el límite de 10 objetivos para este año.";
            return;
        }

        var (ok, _) = await ObjetivoService.CrearObjetivoAsync(objetivo);

        if (ok)
        {
            DialogService.Close(true);
        }
        else
        {
            errorMsg = "Error al crear el objetivo. Por favor intente nuevamente.";
        }
    }

    class EmpleadoItem
    {
        public int Id { get; set; }
        public string NombreCompleto { get; set; } = "";
    }
}
