@page "/objetivos"
@page "/misobjetivos"
@inject Objetivos.Web.Services.ObjetivoService ObjetivoService
@inject Objetivos.Web.Services.ICurrentUserService CurrentUser
@inject Objetivos.Web.Services.ConfiguracionService ConfigService
@inject Radzen.DialogService DialogService
@inject Radzen.NotificationService NotificationService
@inject Objetivos.Web.Services.ExportService ExportService
@inject IJSRuntime JS
@inject Objetivos.Web.Services.ValidacionObjetivoService ValidacionService

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom: 1.5rem;">
    <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Objetivos y Competencias</RadzenText>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenCheckBox Value="verHistorial" TValue="bool" Name="VerHistorial" Change="@OnVerHistorialChanged" />
        <RadzenLabel Text="Ver historial" Component="VerHistorial" Style="margin-right: 1rem;" />
        <RadzenButton Icon="download" Text="Exportar CSV" Click="@OnExportClick" ButtonStyle="ButtonStyle.Success" Visible="@(CurrentUser.Rol == "RRHH" || CurrentUser.Rol == "DIRECTOR_GENERAL" || CurrentUser.EsSuperusuario)" />
        <RadzenButton Icon="add" Text="Nuevo Objetivo" Click="@OnCreateClick" ButtonStyle="ButtonStyle.Primary" Visible="@puedeCrearObjetivo" />
    </RadzenStack>
</RadzenStack>

@if (roleData == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (roleData.Equipo != null && roleData.Personal != null)
    {
        <RadzenTabs>
            <Tabs>
                @if (CurrentUser.EsJefe)
                {
                    <RadzenTabsItem Text="Pendientes de Aprobación">
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem" Style="margin-bottom: 1rem;">
                            <RadzenButton Icon="check_circle" Text="Revisar Aprobaciones" Click="@OnAprobarObjetivosClick" ButtonStyle="ButtonStyle.Primary" />
                        </RadzenStack>
                        <RadzenText TextStyle="TextStyle.Body2" Style="opacity: 0.7;">Los objetivos de tu equipo están pendientes de tu aprobación para poder entrar en evaluación.</RadzenText>
                    </RadzenTabsItem>
                }
                <RadzenTabsItem Text="Objetivos de mi Equipo">
                    @RenderObjetivosEquipo(roleData.Equipo)
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Objetivos">
                    @RenderObjetivos(roleData.Personal, false)
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
    else if (roleData.Equipo != null)
    {
        @RenderObjetivosEquipo(roleData.Equipo)
    }
    else if (roleData.Personal != null)
    {
        var sumaPersonal = roleData.Personal.Sum(o => o.PorcentajePilar);
        @if (!ValidacionService.ValidarTotalExacto(sumaPersonal))
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Lighter" ShowIcon="true" Style="margin-bottom: 1rem;">
                <b>Atención:</b> La suma total de tus objetivos es <b>@sumaPersonal%</b>. Debe ser exactamente <b>100%</b> para que la evaluación sea válida.
                @(sumaPersonal < 100 ? $"Faltan {100 - sumaPersonal}%." : $"Excedes en {sumaPersonal - 100}%.")
            </RadzenAlert>
        }
        @RenderObjetivos(roleData.Personal, false)
    }
    else
    {
        <EmptyState Message="Aún no has creado objetivos. ¡Comienza agregando uno con el botón +" />
    }
}

@code {
    Objetivos.Web.Services.RoleObjetivosData? roleData;
    bool puedeCrearObjetivo;
    bool verHistorial = false;

    protected override async Task OnInitializedAsync()
    {
        bool jefePermitido = await ConfigService.ObtenerConfiguracionBoolAsync("jefe_puede_crear_objetivos") ?? false;
        puedeCrearObjetivo = CurrentUser.EsJefe
            ? (jefePermitido || CurrentUser.Rol == "RRHH" || CurrentUser.Rol == "DIRECTOR_GENERAL")
            : true;
        await LoadData();
    }

    async Task LoadData()
    {
        roleData = await ObjetivoService.GetObjetivosRoleAsync(verHistorial ? null : DateTime.Now.Year);
    }

    async Task OnVerHistorialChanged(bool value)
    {
        verHistorial = value;
        await LoadData();
    }

    [Inject] NavigationManager Nav { get; set; } = null!;

    void OnViewClick(int id, int empleadoId)
    {
        Nav.NavigateTo($"seguimientos/{empleadoId}/objetivo/{id}");
    }

    async Task OnCreateClick()
    {
        var result = await DialogService.OpenAsync<CrearObjetivoDialog>("Crear Nuevo Objetivo",
            new Dictionary<string, object?>(),
            new DialogOptions { Width = "700px", Resizable = true, Draggable = true });

        if (result != null && (bool)result)
        {
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Objetivo creado correctamente");
        }
    }

    async Task OnAprobarObjetivosClick()
    {
        var result = await DialogService.OpenAsync<AprobarObjetivosDialog>("Aprobar Objetivos de mi Equipo",
            new Dictionary<string, object?>(),
            new DialogOptions { Width = "900px", Resizable = true, Draggable = true });

        if (result != null)
        {
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Aprobaciones procesadas");
        }
    }

    async Task OnExportClick()
    {
        if (roleData?.Equipo == null || !roleData.Equipo.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Sin Datos", "No hay objetivos de equipo para exportar.");
            return;
        }
        
        var content = ExportService.ExportObjetivosToCsv(roleData.Equipo);
        var base64 = Convert.ToBase64String(content);
        var fileName = $"Objetivos_{DateTime.Now:yyyyMMdd}.csv";
        
        await JS.InvokeVoidAsync("antigravityDownloadFile", fileName, base64);
    }

    private RenderFragment RenderObjetivosEquipo(List<Objetivos.Web.Domain.Entities.Objetivo> objetivosLista) => __builder =>
    {
        if (objetivosLista == null || !objetivosLista.Any())
        {
            <EmptyState Message="No hay objetivos de equipo para mostrar" />
        }
        else
        {
            var grupos = objetivosLista
                .GroupBy(o => new { o.Empleado, o.Anio })
                .Select(g => {
                    var objetivosEmpleado = g.ToList();
                    decimal sumaPesos = objetivosEmpleado.Sum(o => o.PorcentajePilar);
                    return new UserYearGroup {
                        Empleado = g.Key.Empleado,
                        Anio = g.Key.Anio,
                        Cantidad = objetivosEmpleado.Count,
                        Completados = objetivosEmpleado.Count(o => o.Estado == EstadoObjetivo.COMPLETADO),
                        ProgresoPromedio = sumaPesos > 0 ? (int)Math.Round(objetivosEmpleado.Sum(o => (decimal)o.Progreso * o.PorcentajePilar) / sumaPesos) : 0,
                        Objetivos = objetivosEmpleado
                    };
                })
                .OrderBy(g => g.Empleado.Apellido)
                .ThenBy(g => g.Empleado.Nombre)
                .ThenByDescending(g => g.Anio)
                .ToList();

            <div class="pt-3">
                <RadzenDataGrid Data="@grupos" TItem="UserYearGroup" AllowPaging="true" PageSize="10" AllowSorting="true" Responsive="true">
                    <Template Context="grupo">
                        <RadzenDataGrid Data="@grupo.Objetivos" TItem="Objetivos.Web.Domain.Entities.Objetivo" AllowPaging="false" AllowSorting="true" Responsive="true">
                            <Columns>
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Nombre" Title="Objetivo" />
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Pilar.Nombre" Title="Pilar">
                                    <Template Context="obj">
                                        <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="PorcentajePilar" Title="Peso" Width="80px">
                                    <Template Context="obj">
                                        @obj.PorcentajePilar%
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Deadline" Title="Vencimiento" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Title="Estado" Width="120px">
                                    <Template Context="obj">
                                        <EstadoBadge EstadoObj="@obj.Estado" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Title="Progreso" Width="100px">
                                    <Template Context="obj">
                                        <RadzenProgressBar Value="@obj.Progreso" ShowValue="true" Max="100" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Context="obj" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="160px">
                                    <Template Context="obj">
                                        <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small"
                                                      Click="@(() => OnViewClick(obj.Id, obj.EmpleadoId))" />
                                    </Template>
                                </RadzenDataGridColumn>
                            </Columns>
                        </RadzenDataGrid>
                    </Template>
                    <Columns>
                        <RadzenDataGridColumn TItem="UserYearGroup" Title="Usuario">
                            <Template Context="g">
                                @(string.IsNullOrWhiteSpace(g.Empleado.Apellido) ? g.Empleado.Nombre : $"{g.Empleado.Apellido}, {g.Empleado.Nombre}")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserYearGroup" Property="Anio" Title="Año" Width="100px" />
                        <RadzenDataGridColumn TItem="UserYearGroup" Property="Cantidad" Title="Cantidad" Width="100px" />
                        <RadzenDataGridColumn TItem="UserYearGroup" Title="Completados" Width="120px">
                            <Template Context="g">
                                @g.Completados / @g.Cantidad
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="UserYearGroup" Title="Progreso Ponderado">
                            <Template Context="g">
                                <RadzenProgressBar Value="@g.ProgresoPromedio" ShowValue="true" Max="100" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderObjetivos(List<Objetivos.Web.Domain.Entities.Objetivo> objetivosLista, bool showEmployee) => __builder =>
    {
        if (objetivosLista == null || !objetivosLista.Any())
        {
            <EmptyState Message="Aún no has creado objetivos. ¡Comienza agregando uno con el botón +" />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@objetivosLista" TItem="Objetivos.Web.Domain.Entities.Objetivo" AllowPaging="true" PageSize="10" AllowSorting="true" Responsive="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Pilar.Nombre" Title="Pilar">
                            <Template Context="obj">
                                <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="PorcentajePilar" Title="Peso" Width="80px">
                            <Template Context="obj">
                                @obj.PorcentajePilar%
                            </Template>
                        </RadzenDataGridColumn>
                        @if (showEmployee)
                        {
                            <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Empleado.Nombre" Title="Empleado">
                                <Template Context="obj">
                                    @obj.Empleado.Nombre @obj.Empleado.Apellido
                                </Template>
                            </RadzenDataGridColumn>
                        }
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Anio" Title="Año" Visible="@verHistorial" Width="80px" />
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Property="Deadline" Title="Vencimiento" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Title="Estado" Width="120px">
                            <Template Context="obj">
                                <EstadoBadge EstadoObj="@obj.Estado" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Title="Progreso" Width="100px">
                            <Template Context="obj">
                                <RadzenProgressBar Value="@obj.Progreso" ShowValue="true" Max="100" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivos.Web.Domain.Entities.Objetivo" Context="obj" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="obj">
                                <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Small"
                                              Click="@(() => OnViewClick(obj.Id, obj.EmpleadoId))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    class UserYearGroup 
    {
        public Objetivos.Web.Domain.Entities.Empleado Empleado { get; set; } = null!;
        public int Anio { get; set; }
        public int Cantidad { get; set; }
        public int Completados { get; set; }
        public int ProgresoPromedio { get; set; }
        public List<Objetivos.Web.Domain.Entities.Objetivo> Objetivos { get; set; } = new();
    }
}
