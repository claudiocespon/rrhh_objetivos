@page "/seguimientos/{UsuarioId:int}"
@using Radzen.Blazor
@using Radzen
@inject SeguimientoService SeguimientoService
@inject ICurrentUserService CurrentUser

@if (usuario == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Style="margin-bottom: 2rem;">
        <RadzenButton Icon="arrow_back" Click="@(() => Nav.NavigateTo("seguimientos"))" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" />
        <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">Detalle de Colaborador</RadzenText>
    </RadzenStack>

    <div class="row mb-4">
        <div class="col-md-4">
            <RadzenCard>
                <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                    <div class="rz-avatar" style="width: 80px; height: 80px; font-size: 2rem; border-radius: 50%; background-color: var(--rz-primary); color: white; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                        @($"{(string.IsNullOrEmpty(usuario.Nombre) ? "" : usuario.Nombre[0].ToString())}{(string.IsNullOrEmpty(usuario.Apellido) ? "" : usuario.Apellido[0].ToString())}".ToUpper())
                    </div>
                    <RadzenStack Gap="0" AlignItems="AlignItems.Center">
                        <RadzenText TextStyle="TextStyle.H5" Style="margin: 0;">@usuario.Nombre @usuario.Apellido</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2" Style="opacity: 0.7;">@(usuario.Puesto?.Nombre ?? "Sin Puesto")</RadzenText>
                    </RadzenStack>
                    <RadzenBadge Text="@usuario.Area.Nombre" BadgeStyle="BadgeStyle.Secondary" />
                </RadzenStack>
                <hr />
                <RadzenStack Gap="0.5rem">
                    <div class="d-flex justify-content-between">
                        <RadzenText TextStyle="TextStyle.Caption">Email:</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">@usuario.Email</RadzenText>
                    </div>
                    <div class="d-flex justify-content-between">
                        <RadzenText TextStyle="TextStyle.Caption">Ingreso:</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">@usuario.FechaIngreso.ToString("dd/MM/yyyy")</RadzenText>
                    </div>
                </RadzenStack>
            </RadzenCard>
        </div>
        <div class="col-md-8">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 1rem;">Rendimiento por Pilar</RadzenText>
                <RadzenChart Style="height: 250px;">
                    <RadzenColumnSeries Data="@radarData" CategoryProperty="Pilar" ValueProperty="Score" Title="Rendimiento" TItem="RadarPilarItem" />
                    <RadzenValueAxis Min="0" Max="5" Step="1" />
                </RadzenChart>
            </RadzenCard>
        </div>
    </div>

    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6" Style="margin-bottom: 1rem;">Objetivos del Año (@DateTime.Now.Year)</RadzenText>
        @if (!usuario.Objetivos.Any(o => o.Anio == DateTime.Now.Year))
        {
            <EmptyState Message="Este usuario no tiene objetivos asignados" />
        }
        else
        {
            <RadzenDataGrid Data="@usuario.Objetivos.Where(o => o.Anio == DateTime.Now.Year)" TItem="Objetivo" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive">
                <Columns>
                    <RadzenDataGridColumn TItem="Objetivo" Property="Nombre" Title="Objetivo" />
                    <RadzenDataGridColumn TItem="Objetivo" Property="Pilar.Nombre" Title="Pilar">
                        <Template Context="obj">
                            <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Objetivo" Title="Progreso" Width="150px">
                        <Template Context="obj">
                            <RadzenProgressBar Value="@obj.Progreso" Max="100" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Objetivo" Title="Semaforo" Width="120px">
                        <Template Context="obj">
                            <SemaforoIndicador Promedio="@GetPonderado(obj.Id)" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="Objetivo" Context="obj" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="160px">
                        <Template Context="obj">
                            <RadzenButton Icon="search" Text="Ver" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" 
                                          Click="@(() => Nav.NavigateTo($"seguimientos/{UsuarioId}/objetivo/{obj.Id}"))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
    </RadzenCard>
}

@code {
    [Parameter] public int UsuarioId { get; set; }
    Usuario? usuario;
    List<RadarPilarItem> radarData = new();
    Dictionary<int, double> ponderados = new();

    [Inject] NavigationManager Nav { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var detalle = await SeguimientoService.GetEmpleadoDetalleCompletoAsync(UsuarioId, DateTime.Now.Year);

        if (detalle != null)
        {
            usuario = detalle.Usuario;

            // H-01: Validar acceso por URL
            bool isOwnProfile = !CurrentUser.EsJefe && usuario.Id == CurrentUser.UsuarioId;
            bool isDirectReport = CurrentUser.EsJefe && usuario.JefeId == CurrentUser.UsuarioId;
            bool isAreaDirector = CurrentUser.Rol == "DIRECTOR" && usuario.AreaId == CurrentUser.AreaId;
            bool isHighLevel = CurrentUser.Rol == "RRHH" || CurrentUser.Rol == "DIRECTOR_GENERAL" || CurrentUser.EsSuperusuario;

            if (!isOwnProfile && !isDirectReport && !isAreaDirector && !isHighLevel)
            {
                Nav.NavigateTo("dashboard");
                return;
            }

            radarData = detalle.RadarData;
            ponderados = detalle.Ponderados;
        }
    }

    double GetPonderado(int id) => ponderados.ContainsKey(id) ? ponderados[id] : 0;
}
