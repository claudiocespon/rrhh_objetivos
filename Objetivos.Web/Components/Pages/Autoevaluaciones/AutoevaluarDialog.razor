@using System.Text.Json
@inject AutoevaluacionService AutoevaluacionService
@inject ICurrentUserService CurrentUser
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ConfiguracionService ConfigService

<div>
    @if (objetivo == null)
    {
        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        <RadzenStack Gap="1.5rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" Style="flex-wrap: wrap;">
                <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin: 0;">Objetivo: <b>@ObjetivoNombre</b></RadzenText>
                @if (objetivo?.Pilar != null)
                {
                    <RadzenBadge Text="@objetivo.Pilar.Nombre.Replace("_", " ")"
                                 Style="@($"background-color: {objetivo.Pilar.ColorHex}; color: white; font-size: 0.75rem;")" />
                }
            </RadzenStack>
            
            <RadzenRow>
                <RadzenColumn Size="4">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Valoración *</RadzenText>
                    <EscalaSelector @bind-SelectedId="@scoreEscalaId" />
                </RadzenColumn>
                @if (objetivo?.SoftSkill1 != null)
                {
                    <RadzenColumn Size="4">
                        <RadzenText TextStyle="TextStyle.Subtitle2">@objetivo.SoftSkill1.Nombre</RadzenText>
                        <EscalaSelector @bind-SelectedId="@skill1EscalaId" />
                    </RadzenColumn>
                }
                @if (objetivo?.SoftSkill2 != null)
                {
                    <RadzenColumn Size="4">
                        <RadzenText TextStyle="TextStyle.Subtitle2">@objetivo.SoftSkill2.Nombre</RadzenText>
                        <EscalaSelector @bind-SelectedId="@skill2EscalaId" />
                    </RadzenColumn>
                }
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.Subtitle2">Comentario / Justificación</RadzenText>
                    <div style="position: relative;">
                        <RadzenTextArea @bind-Value="@autoevaluacion.Comentario" Style="width: 100%;" Rows="5" Name="Comentario" 
                                       Placeholder="Rendí mas o menos..." />
                        <div style="position: absolute; bottom: 10px; right: 10px;">
                            <RadzenUpload Url="api/upload/autoevaluacion" Multiple="true" Accept="*/*" 
                                          Complete=@OnUploadComplete Error=@OnUploadError 
                                          Style="display: inline-block;">
                                <ChildContent>
                                    <RadzenButton Text="AGREGAR ARCHIVOS" Variant="Variant.Text" Size="ButtonSize.Small" Icon="attach_file" />
                                </ChildContent>
                            </RadzenUpload>
                        </div>
                    </div>
                </RadzenColumn>
            </RadzenRow>

            @if (adjuntos.Any())
            {
                <RadzenRow>
                    <RadzenColumn Size="12">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Archivos Adjuntos</RadzenText>
                        <RadzenStack Gap="0.5rem" Style="margin-top: 0.5rem;">
                            @foreach (var file in adjuntos)
                            {
                                <RadzenAlert ShowIcon="true" Icon="description" Variant="Variant.Flat" Shade="Shade.Lighter" Size="AlertSize.Small" AllowClose="true"
                                             Close="@(() => adjuntos.Remove(file))">
                                    @Path.GetFileName(file)
                                </RadzenAlert>
                            }
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>
            }

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" Style="margin-top: 1rem;">
                <RadzenButton ButtonStyle="ButtonStyle.Light" Text="CANCELAR" Click="@(() => DialogService.Close(false))" Disabled="@guardando" />
                <RadzenButton Text="GUARDAR AUTOEVALUACIÓN" ButtonStyle="ButtonStyle.Primary" Click="@OnSubmit" Disabled="@guardando" IsBusy="@guardando" BusyText="Guardando..." />
            </RadzenStack>
        </RadzenStack>
    }
</div>

@code {
    [Parameter] public int ObjetivoId { get; set; }
    [Parameter] public string ObjetivoNombre { get; set; } = "";

    Objetivo? objetivo;
    Autoevaluacion autoevaluacion = new();
    List<string> adjuntos = new();
    bool guardando = false;

    // Escala selector backing fields
    int? scoreEscalaId;
    int? skill1EscalaId;
    int? skill2EscalaId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            objetivo = await AutoevaluacionService.GetObjetivoParaAutoevAsync(ObjetivoId);
            if (objetivo == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", "No se encontró el objetivo especificado.");
                DialogService.Close(false);
                return;
            }

            var escalas = await ConfigService.ObtenerEscalasActivasAsync();

            var existing = await AutoevaluacionService.GetExistingAsync(ObjetivoId);
            if (existing != null)
            {
                autoevaluacion = existing;
                adjuntos = JsonSerializer.Deserialize<List<string>>(existing.ArchivosAdjuntosJson) ?? new();

                // Map numeric scores to escala IDs
                if (autoevaluacion.Score > 0)
                    scoreEscalaId = escalas.FirstOrDefault(e => e.ValorNumerico == autoevaluacion.Score)?.Id;
                if (autoevaluacion.SoftSkill1Score > 0)
                    skill1EscalaId = escalas.FirstOrDefault(e => e.ValorNumerico == autoevaluacion.SoftSkill1Score)?.Id;
                if (autoevaluacion.SoftSkill2Score > 0)
                    skill2EscalaId = escalas.FirstOrDefault(e => e.ValorNumerico == autoevaluacion.SoftSkill2Score)?.Id;
            }
            else
            {
                autoevaluacion.ObjetivoId = ObjetivoId;

                // C-06: UsuarioId viene de la tabla Jefes cuando el usuario es un Jefe.
                // Para EmpleadoId debemos buscar el registro en la tabla Empleados por email.
                var empId = await AutoevaluacionService.GetEmpleadoIdByEmailAsync(CurrentUser.Email);
                if (empId == null)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Error", "No se encontró un registro de empleado para su usuario. Contacte a RRHH.");
                    DialogService.Close(false);
                    return;
                }
                autoevaluacion.EmpleadoId = empId.Value;
                autoevaluacion.FechaAutoevaluacion = DateTime.UtcNow;
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Error al cargar la autoevaluación: {ex.Message}");
            DialogService.Close(false);
        }
    }

    void OnUploadComplete(UploadCompleteEventArgs args)
    {
        var response = string.IsNullOrEmpty(args.RawResponse) ? null : JsonSerializer.Deserialize<UploadResponse>(args.RawResponse);
        if (response?.urls != null)
        {
            adjuntos.AddRange(response.urls);
            NotificationService.Notify(NotificationSeverity.Info, "Archivo subido", "El archivo se cargó correctamente.");
        }
    }

    void OnUploadError(UploadErrorEventArgs args)
    {
        NotificationService.Notify(NotificationSeverity.Error, "Error", $"Error al subir archivo: {args.Message}");
    }

    async Task OnSubmit()
    {
        if (guardando) return; // Prevenir doble submit
        guardando = true;
        StateHasChanged();

        try
        {
            // Validación manual: la valoración general es obligatoria
            if (!scoreEscalaId.HasValue)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Validación", "Debe seleccionar una valoración general.");
                return;
            }

            // N-06: Cargar escalas UNA sola vez (antes se llamaba 3 veces a la BD)
            var escalas = await ConfigService.ObtenerEscalasActivasAsync();

            autoevaluacion.EscalaValoracionIdScore = scoreEscalaId;
            if (scoreEscalaId.HasValue)
            {
                var escala = escalas.FirstOrDefault(e => e.Id == scoreEscalaId.Value);
                if (escala?.ValorNumerico.HasValue == true)
                    autoevaluacion.Score = (int)escala.ValorNumerico.Value;
            }

            autoevaluacion.SoftSkill1EscalaValoracionId = skill1EscalaId;
            if (skill1EscalaId.HasValue)
            {
                var escala = escalas.FirstOrDefault(e => e.Id == skill1EscalaId.Value);
                if (escala?.ValorNumerico.HasValue == true)
                    autoevaluacion.SoftSkill1Score = (int)escala.ValorNumerico.Value;
            }

            autoevaluacion.SoftSkill2EscalaValoracionId = skill2EscalaId;
            if (skill2EscalaId.HasValue)
            {
                var escala = escalas.FirstOrDefault(e => e.Id == skill2EscalaId.Value);
                if (escala?.ValorNumerico.HasValue == true)
                    autoevaluacion.SoftSkill2Score = (int)escala.ValorNumerico.Value;
            }

            // Lista de evidencias vacía (se removió la sección de Evidencias Clave)
            var result = await AutoevaluacionService.GuardarAutoevaluacionAsync(autoevaluacion, new List<string>(), adjuntos);
            if (result.success)
                DialogService.Close(true);
            else
                NotificationService.Notify(NotificationSeverity.Error, "Error", $"No se pudo guardar la autoevaluación: {result.errorMsg}", duration: 10000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error al guardar", $"Ocurrió un error: {ex.Message}");
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    class UploadResponse { public List<string> urls { get; set; } = new(); }
}
