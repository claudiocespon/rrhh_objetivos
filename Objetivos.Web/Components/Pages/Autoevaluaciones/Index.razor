@page "/autoevaluacion"
@using System.Text.Json
@inject AutoevaluacionService AutoevaluacionService
@inject ICurrentUserService CurrentUser
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

<RadzenText TextStyle="TextStyle.H4" Style="margin-bottom: 1.5rem;">Autoevaluaciones</RadzenText>

@if (loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (CurrentUser.EsJefe)
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="@(CurrentUser.Rol == "DIRECTOR_GENERAL" ? "Autoevaluaciones de la Organización" : "Autoevaluaciones de mi Equipo")">
                    @RenderAutoevaluaciones(autoevaluacionesEquipo, true)
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Autoevaluaciones">
                    @RenderAutoevaluaciones(autoevaluacionesPersonal, false)
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
    else
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="Pendientes de Autoevaluar">
                    @RenderPendientes(objetivosPendientes)
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Autoevaluaciones">
                    @RenderAutoevaluaciones(autoevaluacionesPersonal, false)
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
}

@code {
    List<Autoevaluacion>? autoevaluacionesPersonal;
    List<Autoevaluacion>? autoevaluacionesEquipo;
    List<Objetivo>? objetivosPendientes;
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await AutoevaluacionService.GetAutoevaluacionesAsync(CurrentUser);
            autoevaluacionesPersonal = data.Personal;
            autoevaluacionesEquipo = data.Equipo;

            // T-07: Cargar objetivos pendientes de autoevaluación para empleados
            if (!CurrentUser.EsJefe)
            {
                objetivosPendientes = await AutoevaluacionService.GetObjetivosPendientesAutoevAsync(CurrentUser);
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", $"Error al cargar autoevaluaciones: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    async Task OnAutoevaluarClick(Objetivo obj)
    {
        var result = await DialogService.OpenAsync<Autoevaluaciones.AutoevaluarDialog>("Mi Autoevaluación",
            new Dictionary<string, object?> {
                { "ObjetivoId", obj.Id },
                { "ObjetivoNombre", obj.Nombre }
            },
            new DialogOptions { Width = "600px" });

        if (result == true)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Autoevaluación guardada correctamente");
            // Recargar datos
            var data = await AutoevaluacionService.GetAutoevaluacionesAsync(CurrentUser);
            autoevaluacionesPersonal = data.Personal;
            autoevaluacionesEquipo = data.Equipo;
            if (!CurrentUser.EsJefe)
            {
                objetivosPendientes = await AutoevaluacionService.GetObjetivosPendientesAutoevAsync(CurrentUser);
            }
            StateHasChanged();
        }
    }

    private RenderFragment RenderPendientes(List<Objetivo>? lista) => __builder =>
    {
        if (lista == null || !lista.Any())
        {
            <EmptyState Message="No hay objetivos pendientes de autoevaluar. ¡Felicidades!" />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@lista" TItem="Objetivo" AllowPaging="true" PageSize="10" AllowSorting="true" Responsive="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Objetivo" Property="Pilar.Nombre" Title="Pilar">
                            <Template Context="obj">
                                @if (obj.Pilar != null)
                                {
                                    <RadzenBadge Text="@obj.Pilar.Nombre.Replace("_", " ")" Style="@($"background-color: {obj.Pilar.ColorHex}; color: white;")" />
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Objetivo" Property="Deadline" Title="Vencimiento" FormatString="{0:dd/MM/yyyy}" Width="150px" />
                        <RadzenDataGridColumn TItem="Objetivo" Property="Descripcion" Title="Descripción" />
                        <RadzenDataGridColumn TItem="Objetivo" Context="obj" Filterable="false" Sortable="false" TextAlign="TextAlign.Right" Width="160px">
                            <Template Context="obj">
                                <RadzenButton Icon="rate_review" Text="Autoevaluar" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" Size="ButtonSize.Small"
                                              Click="@(() => OnAutoevaluarClick(obj))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };

    private RenderFragment RenderAutoevaluaciones(List<Autoevaluacion>? lista, bool showEmployee) => __builder =>
    {
        if (lista == null || !lista.Any())
        {
            <EmptyState Message="El empleado aún no ha realizado autoevaluaciones" />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@lista" TItem="Autoevaluacion" AllowPaging="true" PageSize="10" AllowSorting="true" Responsive="true">
                    <Columns>
                        @if (showEmployee)
                        {
                            <RadzenDataGridColumn TItem="Autoevaluacion" Property="Objetivo.Empleado.Nombre" Title="Colaborador">
                                <Template Context="ae">
                                    @if (ae.Objetivo?.Empleado != null)
                                    {
                                        @ae.Objetivo.Empleado.Nombre @ae.Objetivo.Empleado.Apellido
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        }
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Valoración" Width="120px">
                            <Template Context="ae">
                                @(ae.EscalaValoracionScore?.Etiqueta ?? "-")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="Comentario" Title="Comentario" />
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Competencias Blandas" Width="220px">
                            <Template Context="ae">
                                <RadzenStack Gap="0.5rem">
                                    @if (ae.Objetivo?.SoftSkill1 != null)
                                    {
                                        <div class="d-flex justify-content-between align-items-center">
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin:0; flex: 1;">@ae.Objetivo.SoftSkill1.Nombre</RadzenText>
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin:0;">@(ae.SoftSkill1EscalaValoracion?.Etiqueta ?? "-")</RadzenText>
                                        </div>
                                    }
                                    @if (ae.Objetivo?.SoftSkill2 != null)
                                    {
                                        <div class="d-flex justify-content-between align-items-center">
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin:0; flex: 1;">@ae.Objetivo.SoftSkill2.Nombre</RadzenText>
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin:0;">@(ae.SoftSkill2EscalaValoracion?.Etiqueta ?? "-")</RadzenText>
                                        </div>
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Evidencias y Adjuntos" Width="250px">
                            <Template Context="ae">
                                @{
                                    var evidencias = JsonSerializer.Deserialize<List<string>>(ae.EvidenciasMencionadasJson) ?? new();
                                    var adjuntos = JsonSerializer.Deserialize<List<string>>(ae.ArchivosAdjuntosJson) ?? new();
                                }
                                <RadzenStack Gap="0.5rem">
                                    @if (evidencias.Any())
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; margin-bottom: 0.2rem;">Relatadas:</RadzenText>
                                        @foreach (var ev in evidencias)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; line-height: 1.2;">• @ev</RadzenText>
                                        }
                                    }
                                    @if (adjuntos.Any())
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; margin-top: 0.5rem; margin-bottom: 0.2rem;">Archivos:</RadzenText>
                                        @foreach (var adj in adjuntos)
                                        {
                                            <RadzenLink Path="@(NavigationManager.BaseUri + adj.TrimStart('/'))" Target="_blank" Style="font-size: 0.75rem; display: block;">
                                                <RadzenIcon Icon="description" Style="font-size: 0.8rem; vertical-align: middle;" /> @Path.GetFileName(adj)
                                            </RadzenLink>
                                        }
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="FechaAutoevaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="110px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };
}
