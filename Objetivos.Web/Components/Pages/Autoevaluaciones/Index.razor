@page "/autoevaluacion"
@using System.Text.Json
@inject AutoevaluacionService AutoevaluacionService
@inject ICurrentUserService CurrentUser

<RadzenText TextStyle="TextStyle.H4" Style="margin-bottom: 1.5rem;">Autoevaluaciones</RadzenText>

@if (loading)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    @if (CurrentUser.EsJefe)
    {
        <RadzenTabs>
            <Tabs>
                <RadzenTabsItem Text="@(CurrentUser.Rol == "DIRECTOR_GENERAL" ? "Autoevaluaciones de la Organización" : "Autoevaluaciones de mi Equipo")">
                    @RenderAutoevaluaciones(autoevaluacionesEquipo, true)
                </RadzenTabsItem>
                <RadzenTabsItem Text="Mis Autoevaluaciones">
                    @RenderAutoevaluaciones(autoevaluacionesPersonal, false)
                </RadzenTabsItem>
            </Tabs>
        </RadzenTabs>
    }
    else
    {
        @RenderAutoevaluaciones(autoevaluacionesPersonal, false)
    }
}

@code {
    List<Autoevaluacion>? autoevaluacionesPersonal;
    List<Autoevaluacion>? autoevaluacionesEquipo;
    bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var data = await AutoevaluacionService.GetAutoevaluacionesAsync(CurrentUser);
        autoevaluacionesPersonal = data.Personal;
        autoevaluacionesEquipo = data.Equipo;
        loading = false;
    }

    private RenderFragment RenderAutoevaluaciones(List<Autoevaluacion>? lista, bool showEmployee) => __builder =>
    {
        if (lista == null || !lista.Any())
        {
            <EmptyState Message="El empleado aún no ha realizado autoevaluaciones" />
        }
        else
        {
            <div class="pt-3">
                <RadzenDataGrid Data="@lista" TItem="Autoevaluacion" AllowPaging="true" PageSize="10" AllowSorting="true" Responsive="true">
                    <Columns>
                        @if (showEmployee)
                        {
                            <RadzenDataGridColumn TItem="Autoevaluacion" Property="Objetivo.Empleado.Nombre" Title="Colaborador">
                                <Template Context="ae">
                                    @ae.Objetivo.Empleado.Nombre @ae.Objetivo.Empleado.Apellido
                                </Template>
                            </RadzenDataGridColumn>
                        }
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="Objetivo.Nombre" Title="Objetivo" />
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Valoración" Width="120px">
                            <Template Context="ae">
                                @(ae.EscalaValoracionScore?.Etiqueta ?? "-")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="Comentario" Title="Comentario" />
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Habilidades Blandas" Width="220px">
                            <Template Context="ae">
                                <RadzenStack Gap="0.5rem">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin:0; flex: 1;">@ae.Objetivo.SoftSkill1.Nombre</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin:0;">@(ae.SoftSkill1EscalaValoracion?.Etiqueta ?? "-")</RadzenText>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin:0; flex: 1;">@ae.Objetivo.SoftSkill2.Nombre</RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin:0;">@(ae.SoftSkill2EscalaValoracion?.Etiqueta ?? "-")</RadzenText>
                                    </div>
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Title="Evidencias y Adjuntos" Width="250px">
                            <Template Context="ae">
                                @{
                                    var evidencias = JsonSerializer.Deserialize<List<string>>(ae.EvidenciasMencionadasJson) ?? new();
                                    var adjuntos = JsonSerializer.Deserialize<List<string>>(ae.ArchivosAdjuntosJson) ?? new();
                                }
                                <RadzenStack Gap="0.5rem">
                                    @if (evidencias.Any())
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; margin-bottom: 0.2rem;">Relatadas:</RadzenText>
                                        @foreach (var ev in evidencias)
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="margin: 0; line-height: 1.2;">• @ev</RadzenText>
                                        }
                                    }
                                    @if (adjuntos.Any())
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="font-weight: bold; margin-top: 0.5rem; margin-bottom: 0.2rem;">Archivos:</RadzenText>
                                        @foreach (var adj in adjuntos)
                                        {
                                            <RadzenLink Path="@adj" Target="_blank" Style="font-size: 0.75rem; display: block;">
                                                <RadzenIcon Icon="description" Style="font-size: 0.8rem; vertical-align: middle;" /> @Path.GetFileName(adj)
                                            </RadzenLink>
                                        }
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Autoevaluacion" Property="FechaAutoevaluacion" Title="Fecha" FormatString="{0:dd/MM/yyyy}" Width="110px" />
                    </Columns>
                </RadzenDataGrid>
            </div>
        }
    };
}
