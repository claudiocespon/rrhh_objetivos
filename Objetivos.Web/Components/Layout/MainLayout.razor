@inherits LayoutComponentBase
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav
@inject NotificacionService NotificacionService

@if (!CurrentUser.EstaAutenticado)
{
    <RadzenLayout>
        <RadzenBody>
            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height: 100vh;">
                <RadzenText TextStyle="TextStyle.H6">Redirigiendo al inicio de sesión...</RadzenText>
            </RadzenStack>
        </RadzenBody>
    </RadzenLayout>
}
else
{
    <RadzenLayout Style="grid-template-areas: 'rz-header rz-header' 'rz-sidebar rz-body';">
        <RadzenHeader>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="padding: 0 1rem; width: 100%; height: 100%;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
                    <div class="logo-header">
                        <img src="Pqtalent.png" class="logo-img" alt="PQ-Talent Logo" />
                        <RadzenText TextStyle="TextStyle.H6" Style="margin: 0; font-weight: bold; color: white;">PQ-Talent</RadzenText>
                    </div>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                    <div style="position: relative; display: inline-flex; align-items: center;">
                        <RadzenIcon Icon="notifications" Style="color: white; cursor: pointer; font-size: 1.5rem;" @onclick="@TogglePanel" />
                        @if (unreadCount > 0)
                        {
                            <RadzenBadge Text="@unreadCount.ToString()" BadgeStyle="BadgeStyle.Danger" IsPill="true"
                                         Style="position: absolute; top: -6px; right: -8px; pointer-events: none;" />
                        }
                    </div>
                    <NotificacionPanel @bind-Visible="panelVisible" UsuarioId="@CurrentUser.UsuarioId"
                                       OnLeidaChanged="@OnLeidaChanged" />
                    <RadzenText Style="color: white; margin: 0;">
                        Bienvenido, <b>@CurrentUser.NombreCompleto</b>
                    </RadzenText>
                    <RadzenButton Text="Cerrar Sesión" Icon="logout" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@CerrarSesion" Variant="Variant.Text" Style="color: white;" />
                </RadzenStack>
            </RadzenStack>
        </RadzenHeader>
        <RadzenSidebar @bind-Expanded="@sidebarExpanded">
            <NavMenu />
        </RadzenSidebar>
        <RadzenBody>
            <RadzenStack Style="padding: 2rem;">
                @Body
            </RadzenStack>
        </RadzenBody>
    </RadzenLayout>

    <RadzenComponents />
}

@code {
    bool sidebarExpanded = true;
    bool panelVisible = false;
    int unreadCount = 0;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CurrentUser.InitializeAsync();

            if (!CurrentUser.EstaAutenticado && !Nav.Uri.Contains("/login"))
            {
                Nav.NavigateTo("login");
            }
            else if (CurrentUser.EstaAutenticado)
            {
                unreadCount = await NotificacionService.GetNoLeidasCountAsync(CurrentUser.UsuarioId);
            }
            StateHasChanged();
        }
    }

    void TogglePanel()
    {
        panelVisible = !panelVisible;
    }

    async Task OnLeidaChanged()
    {
        unreadCount = await NotificacionService.GetNoLeidasCountAsync(CurrentUser.UsuarioId);
        StateHasChanged();
    }

    async Task CerrarSesion()
    {
        await CurrentUser.CerrarSesionAsync();
        Nav.NavigateTo("login", forceLoad: true);
    }
}
