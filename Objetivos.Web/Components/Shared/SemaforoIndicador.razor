@inject RendimientoService Rendimiento

<div class="d-flex align-items-center">
    <div style="width: 12px; height: 12px; border-radius: 50%; background-color: @Rendimiento.GetSemaforoColor(Promedio); margin-right: 8px;"></div>
    <RadzenText TextStyle="TextStyle.Caption">@(Rendimiento.DisplayScore(Promedio))/100</RadzenText>
</div>

@code {
    [Parameter] public double Promedio { get; set; }
}
