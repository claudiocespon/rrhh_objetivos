<div class="d-flex flex-column align-items-center justify-content-center p-5" style="min-height: 200px; color: var(--rz-text-secondary-color);">
    <RadzenIcon Icon="info" Style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;" />
    <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H3" Style="margin-bottom: 0.5rem;">@Message</RadzenText>
    @if (!string.IsNullOrEmpty(SubMessage))
    {
        <RadzenText TextStyle="TextStyle.Body2">@SubMessage</RadzenText>
    }
</div>

@code {
    [Parameter] public string Message { get; set; } = "No hay datos disponibles";
    [Parameter] public string? SubMessage { get; set; }
}
